{
  "name": "typescript-nextjs-starter",
  "version": "1.0.0",
  "private": true,
  "description": "A TypeScript starter for Next.js that includes all you need to build amazing projects",
  "keywords": [
    "nextjs",
    "starter",
    "typescript"
  ],
  "license": "MIT",
  "author": "João Pedro Schmitz (@jpedroschmitz)",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3030",
    "dev:web": "next dev -p 3030",
    "build": "next build",
    "start": "next start -p 3030",
    "test": "pnpm test:lumi",
    "test:lumi": "SKIP_ENV_VALIDATION=1 tsx --test tests/lumi/dialogs.spec.ts",
    "waha:init": "cd infra/waha && docker run --rm -v \"$(pwd)\":/app/env devlikeapro/waha:arm init-waha /app/env",
    "waha:up": "docker compose --env-file .env -f infra/waha/docker-compose.yml up -d",
    "waha:down": "docker compose --env-file .env -f infra/waha/docker-compose.yml down",
    "waha:logs": "docker compose --env-file .env -f infra/waha/docker-compose.yml logs -f waha",
    "waha:pull": "docker pull devlikeapro/waha:arm",
    "waha:smoke": "bash scripts/waha-smoke.sh",
    "type-check": "next typegen && tsc --noEmit",
    "build:analyze": "next build && next experimental-analyze",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "format:ci": "oxfmt --list-different .",
    "postinstall": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.2.0",
    "@hugeicons/core-free-icons": "3.3.0",
    "@hugeicons/react": "1.1.5",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@t3-oss/env-nextjs": "0.13.10",
    "@tailwindcss/postcss": "4.2.1",
    "babel-plugin-react-compiler": "1.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.575.0",
    "next": "16.1.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.27",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.15.0",
    "postcss": "8.5.6",
    "shadcn": "3.8.5",
    "tailwindcss": "^4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
