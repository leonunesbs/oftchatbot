NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
CONVEX_DEPLOY_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Opcional: price fixo no Stripe (fallback usado no checkout quando aplicavel)
STRIPE_PRICE_ID=
# Stripe Link no Checkout nao exige nova env.
# A habilitacao e feita no Dashboard (test/live) em Payment methods.
# Opcional: base da API do oftchatbot para notificacoes WhatsApp.
# OFTCHATBOT_API_BASE_URL=http://localhost:3030
N8N_OFTAGENDA_FORWARD_ORIGIN=https://agenda.oftleonardo.com.br

# Resend (envio de email para vinculacao WhatsApp)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@oftleonardo.com.br

# Criptografia ponta a ponta da triagem (cliente -> Convex)
# Valor em base64 SPKI (uma unica linha, sem -----BEGIN/END-----).
NEXT_PUBLIC_TRIAGE_E2E_PUBLIC_KEY=
# Versao da chave para rotacao (ex.: v1, v2)
NEXT_PUBLIC_TRIAGE_E2E_KEY_VERSION=v1
# Chave privada RSA PKCS8 para descriptografia no servidor.
# Pode ser PEM completo (com \n) ou base64 DER em linha unica.
TRIAGE_E2E_PRIVATE_KEY=
