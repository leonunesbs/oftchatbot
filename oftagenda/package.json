{
  "name": "oftagenda",
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "private": true,
  "description": "A TypeScript starter for Next.js that includes all you need to build amazing projects",
  "keywords": [
    "nextjs",
    "starter",
    "typescript"
  ],
  "license": "MIT",
  "author": "João Pedro Schmitz (@jpedroschmitz)",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-safe.mjs",
    "dev:web": "pnpm run dev:next",
    "dev:convex": "npx convex dev",
    "dev:next": "pnpm exec next dev --webpack -p ${NEXT_PORT:-3001}",
    "build": "if [ -n \"$CONVEX_DEPLOY_KEY\" ]; then npx convex deploy --cmd 'next build'; else next build; fi",
    "start": "next start",
    "type-check": "next typegen && tsc --noEmit",
    "build:analyze": "next build && next experimental-analyze",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "format:ci": "oxfmt --list-different ."
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@clerk/localizations": "4.2.1",
    "@clerk/nextjs": "7.0.4",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/react": "0.3.2",
    "@hugeicons/core-free-icons": "4.0.0",
    "@hugeicons/react": "1.1.6",
    "@next/third-parties": "16.1.6",
    "@t3-oss/env-nextjs": "0.13.10",
    "@tanstack/react-table": "8.21.3",
    "babel-plugin-react-compiler": "1.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "convex": "1.33.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "lucide-react": "0.577.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.4",
    "resend": "6.9.3",
    "sonner": "2.0.7",
    "stripe": "20.4.1",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "baseline-browser-mapping": "2.10.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.17.0",
    "postcss": "8.5.8",
    "shadcn": "4.0.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  }
}
