---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import ScheduleConsultationSection from "@/components/ScheduleConsultationSection.astro";
import { buttonVariants } from "@/components/ui/button";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

const title =
  "Tela de Amsler Online Grátis | Teste de Distorção Visual Central";
const description =
  "Faça o teste de Amsler online para triagem de distorções no centro da visão. Veja orientações, sinais de alerta e quando procurar avaliação com oftalmologista especialista em retina.";
const keywords =
  "tela de amsler online, teste de amsler, grade de amsler, metamorfopsia, visão embaçada central, distorção visual central, degeneração macular, especialista em retina";
const canonical = new URL("/tela-de-amsler", siteConfig.canonical).href;

const howToSteps = [
  {
    name: "Prepare o ambiente",
    text: "Use seus óculos habituais para perto, se necessário, e mantenha iluminação confortável.",
  },
  {
    name: "Posicione a tela",
    text: "Segure celular ou monitor entre 30 e 40 cm dos olhos para manter a escala adequada.",
  },
  {
    name: "Teste um olho por vez",
    text: "Cubra um olho sem pressionar e mantenha o outro olho relaxado.",
  },
  {
    name: "Fixe o ponto central",
    text: "Olhe para o ponto no centro por alguns segundos e observe se há linhas tortas, onduladas ou falhas.",
  },
  {
    name: "Repita no outro olho",
    text: "Compare com sua visão habitual e procure avaliação se notar mudança nova.",
  },
];

const faqItems = [
  {
    question: "Para que serve a Tela de Amsler?",
    answer:
      "A Tela de Amsler é uma ferramenta de triagem para detectar alterações no centro da visão, como linhas onduladas, áreas apagadas ou deformações que podem sugerir problema macular.",
  },
  {
    question: "Se as linhas parecerem tortas ou faltando, o que devo fazer?",
    answer:
      "Agende avaliação com oftalmologista o quanto antes. Alterações novas no centro da visão precisam de exame presencial para diagnóstico e conduta corretos.",
  },
  {
    question: "O teste online substitui consulta oftalmológica?",
    answer:
      "Não. O teste é orientativo e não substitui consulta, exame de fundo de olho, OCT e demais avaliações clínicas.",
  },
  {
    question: "Quais doenças podem estar associadas a alterações na grade?",
    answer:
      "As alterações podem ocorrer em doenças da mácula e retina, como degeneração macular relacionada à idade (DMRI), edema macular e outras condições retinianas. Apenas consulta médica confirma a causa.",
  },
  {
    question: "Com que frequência devo fazer a Tela de Amsler?",
    answer:
      "Pacientes com risco para doença macular podem usar a grade regularmente conforme orientação médica. Em caso de mudança súbita, procure atendimento sem esperar a próxima rotina.",
  },
  {
    question: "Como agendar avaliação especializada em retina?",
    answer:
      "Use o botão de agendamento nesta página para falar com a equipe via WhatsApp e escolher a cidade de atendimento.",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Início",
      item: siteConfig.canonical,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Tela de Amsler",
      item: canonical,
    },
  ],
};

const medicalPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: "Tela de Amsler Online",
  description,
  url: canonical,
  inLanguage: "pt-BR",
  about: {
    "@type": "MedicalCondition",
    name: "Metamorfopsia",
    alternateName: "Distorção visual central",
  },
  specialty: {
    "@type": "MedicalSpecialty",
    name: "Ophthalmology",
  },
  reviewedBy: {
    "@type": "Physician",
    name: siteConfig.name,
    url: siteConfig.canonical,
  },
  lastReviewed: new Date().toISOString().split("T")[0],
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Como usar a Tela de Amsler online",
  description:
    "Passo a passo simples para triagem de distorções no centro da visão com grade de Amsler.",
  totalTime: "PT1M",
  step: howToSteps.map((step, index) => ({
    "@type": "HowToStep",
    position: index + 1,
    name: step.name,
    text: step.text,
  })),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const allSchemas = [breadcrumbSchema, medicalPageSchema, howToSchema, faqSchema];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogType="article"
>
  <Fragment slot="head">
    {
      allSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <meta name="subject" content="Tela de Amsler Online" />
    <meta name="topic" content="Oftalmologia - Retina" />
    <meta name="classification" content="Health" />
    <meta name="category" content="Saúde - Oftalmologia" />
    <link rel="preconnect" href="https://api.whatsapp.com" />
  </Fragment>

  <Header />
  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative mx-auto max-w-3xl overflow-x-clip pt-4 sm:pt-6"
  >
    <nav aria-label="Breadcrumb" class="px-4 pt-4 pb-2">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li>
          <a href="/" class="transition-colors hover:text-foreground">Início</a>
        </li>
        <li aria-hidden="true" class="select-none">/</li>
        <li>
          <span class="font-medium text-foreground" aria-current="page"
            >Tela de Amsler</span
          >
        </li>
      </ol>
    </nav>

    <article class="space-y-12 px-4 py-12">
      <header class="space-y-4 text-center">
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
          Tela de Amsler Online
        </h1>
        <p class="mx-auto max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
          Teste rápido de triagem para identificar possíveis distorções no centro
          da visão, como linhas tortas, onduladas ou áreas apagadas.
        </p>
        <p class="mx-auto max-w-2xl text-sm text-muted-foreground">
          Conteúdo revisado por oftalmologista. Ferramenta orientativa, sem
          substituir consulta médica.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
          <a
            href="#grade-amsler"
            class={buttonVariants({ variant: "default", size: "lg" })}
          >
            Fazer teste agora
          </a>
          <a
            href="#agendar"
            class={buttonVariants({ variant: "outline", size: "lg" })}
          >
            Agendar avaliação
          </a>
        </div>
      </header>

      <section class="space-y-8" id="como-funciona">
        <div class="space-y-2 text-center">
          <h2 class="text-xl font-bold tracking-tight sm:text-2xl">
            Como Funciona a Tela de Amsler
          </h2>
          <p class="text-sm text-muted-foreground">
            5 passos simples para testar cada olho com segurança
          </p>
        </div>

        <ol class="relative mx-auto max-w-xl space-y-0">
          {
            howToSteps.map((step, index) => (
              <li class="relative flex gap-5 pb-8 last:pb-0">
                {index < howToSteps.length - 1 && (
                  <div
                    class="absolute left-[19px] top-10 bottom-0 w-px bg-border"
                    aria-hidden="true"
                  />
                )}
                <div class="relative z-10 flex size-10 shrink-0 items-center justify-center rounded-full border-2 border-brand bg-brand/10 text-sm font-bold text-brand">
                  {index + 1}
                </div>
                <div class="flex flex-col gap-1 pt-1.5">
                  <h3 class="text-sm font-semibold leading-tight">
                    {step.name}
                  </h3>
                  <p class="text-sm leading-relaxed text-muted-foreground">
                    {step.text}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="space-y-4">
        <h2 class="text-center text-xl font-bold tracking-tight sm:text-2xl">
          Sobre o Teste de Amsler
        </h2>
        <div
          class="mx-auto max-w-2xl space-y-3 text-sm leading-relaxed text-muted-foreground"
        >
          <p>
            A Tela de Amsler é uma ferramenta de triagem para alterações da visão
            central, como linhas onduladas, áreas apagadas ou deformações.
            Ela é útil para auto-observação entre consultas, especialmente em
            pacientes com risco para doenças da mácula.
          </p>
          <p>
            Se você notar mudança nova em um dos olhos, não espere evolução dos
            sintomas. Alterações súbitas no centro da visão precisam de exame
            presencial para diagnóstico e conduta corretos.
          </p>
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-4 text-sm leading-relaxed">
            <strong class="text-foreground">Aviso médico:</strong> a Tela de
            Amsler é uma triagem e não substitui consulta oftalmológica. Em caso
            de piora súbita da visão central, mancha escura nova ou distorção
            progressiva das linhas, procure atendimento com prioridade.
          </div>
        </div>
      </section>

      <section class="space-y-4">
        <div class="text-center">
          <h2
            id="grade-amsler"
            tabindex="-1"
            class="text-lg font-semibold text-foreground outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            Agora faça o teste de Amsler
          </h2>
          <p id="amsler-grid-instrucao" class="mt-1 text-sm text-muted-foreground">
            Fixe o ponto central e observe se alguma linha parece deformada.
          </p>
        </div>
        <div
          class="mx-auto w-full max-w-[560px]"
        >
          <div
            class="amsler-grid relative aspect-square w-full rounded-sm border-2 border-foreground bg-background"
            role="img"
            aria-label="Grade de Amsler com ponto central"
            aria-describedby="amsler-grid-instrucao"
          >
            <span
              class="absolute top-1/2 left-1/2 size-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-destructive"
              aria-hidden="true"></span>
          </div>
        </div>
      </section>

      <section class="space-y-6" id="faq-amsler">
        <h2 class="text-center text-xl font-bold tracking-tight sm:text-2xl">
          Perguntas frequentes sobre Tela de Amsler
        </h2>
        <div
          class="mx-auto max-w-2xl divide-y divide-border rounded-xl border border-border"
        >
            {
              faqItems.map((item) => (
                <details class="group px-5 py-4">
                  <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-foreground [&::-webkit-details-marker]:hidden">
                    <span class="pr-4">{item.question}</span>
                    <svg
                      class="size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="m19 9-7 7-7-7"
                      />
                    </svg>
                  </summary>
                  <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                    {item.answer}
                  </p>
                </details>
              ))
            }
        </div>
      </section>

      <ScheduleConsultationSection
        id="agendar"
        title="Agende sua avaliação oftalmológica"
        description="Alterações na grade podem estar ligadas a doenças da retina e precisam de confirmação clínica. Agende sua consulta com especialista para diagnóstico seguro e conduta adequada."
        whatsappMessageTemplate="Olá, Dr. Leonardo! Gostaria de agendar uma avaliação da visão central em {city}."
        triggerLabel="Agendar avaliação"
        triggerGtmId="gtm-page-amsler-schedule-whatsapp"
        agendaLinkGtmId="gtm-page-amsler-schedule-agenda"
        onlineBookingLinkId="gtm-page-amsler-dialog-agendar-online"
      />

      <footer class="space-y-6 border-t border-border pt-8">
        <div
          class="mx-auto max-w-2xl rounded-xl border border-amber-500/20 bg-amber-500/5 p-4"
        >
          <p class="text-center text-xs leading-relaxed text-muted-foreground">
            <strong>Aviso médico:</strong> Este conteúdo é educativo e não oferece
            diagnóstico. Em caso de sintomas persistentes, busque consulta com
            médico oftalmologista.
          </p>
        </div>
        <nav
          aria-label="Links relacionados"
          class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-muted-foreground"
        >
          <a href="/" class="transition-colors hover:text-foreground"
            >Página Inicial</a
          >
          <a href="/#atuacao" class="transition-colors hover:text-foreground"
            >Especialidades</a
          >
          <a href="/#atendimento" class="transition-colors hover:text-foreground"
            >Cidades de Atendimento</a
          >
          <a
            href="/acuidade-visual"
            class="transition-colors hover:text-foreground"
            >Teste de Acuidade Visual</a
          >
          <a
            href="/calculadora-olho-seco"
            class="transition-colors hover:text-foreground"
            >Calculadora de olho seco</a
          >
          <a
            href={siteConfig.partnerApps.oftagenda}
            class="transition-colors hover:text-foreground"
            >Agendamento Online</a
          >
          <a href="/conteudos" class="transition-colors hover:text-foreground"
            >Conteúdos</a
          >
        </nav>
      </footer>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .amsler-grid {
    --grid-line-color: color-mix(
      in oklch,
      var(--color-foreground) 70%,
      transparent
    );
    background-image:
      linear-gradient(to right, transparent calc(100% - 1px), var(--grid-line-color) calc(100% - 1px)),
      linear-gradient(to bottom, transparent calc(100% - 1px), var(--grid-line-color) calc(100% - 1px));
    background-size: calc(100% / 20) calc(100% / 20);
  }
</style>
