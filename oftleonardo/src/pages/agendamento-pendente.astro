---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import WhatsAppFloat from "@/components/WhatsAppFloat";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

const title = "Agendamento Pendente de Pagamento | Leonardo Nunes";
const description =
  "Seu agendamento foi registrado e está pendente de pagamento. Conclua o pagamento pelo link enviado no e-mail para confirmar sua consulta.";
---

<Layout title={title} description={description}>
  <Header />

  <main id="conteudo-principal" tabindex="-1" class="relative isolate overflow-x-clip">
    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
      <section class="rounded-xl border border-border/50 bg-card p-6 shadow-sm sm:p-8">
        <p class="inline-flex rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-xs font-semibold tracking-wide text-amber-700 dark:text-amber-300">
          Agendamento pendente
        </p>
        <h1 class="mt-4 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
          Seu agendamento foi criado e aguarda pagamento
        </h1>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
          Enviamos um e-mail com o link de pagamento. Após concluir o pagamento, seu agendamento será
          confirmado automaticamente.
        </p>

        <div class="mt-6 rounded-xl border border-border/60 bg-secondary/30 p-4 sm:p-5">
          <h2 class="text-sm font-semibold text-foreground">Resumo do agendamento</h2>
          <dl class="mt-3 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-3">
              <dt class="text-muted-foreground">Código</dt>
              <dd id="pending-booking-uid" class="font-medium text-foreground">-</dd>
            </div>
            <div class="flex items-center justify-between gap-3">
              <dt class="text-muted-foreground">Cidade</dt>
              <dd id="pending-booking-city" class="font-medium text-foreground">-</dd>
            </div>
            <div class="flex items-center justify-between gap-3">
              <dt class="text-muted-foreground">Data e horário</dt>
              <dd id="pending-booking-start" class="font-medium text-foreground">-</dd>
            </div>
            <div class="flex items-center justify-between gap-3">
              <dt class="text-muted-foreground">Status</dt>
              <dd id="pending-booking-status" class="font-medium text-foreground">Pendente de pagamento</dd>
            </div>
          </dl>
        </div>

        <div class="mt-6 rounded-xl border border-border/60 bg-secondary/20 p-4 text-sm text-muted-foreground">
          <p>
            Não encontrou o e-mail? Verifique caixa de spam/lixo eletrônico. Se precisar de ajuda,
            fale com nossa equipe no WhatsApp.
          </p>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={siteConfig.partnerApps.oftagenda}
            class="inline-flex h-10 items-center justify-center rounded-md border border-border bg-background px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            Voltar ao agendamento
          </a>
          <a
            href={`https://api.whatsapp.com/send?phone=${siteConfig.phone.replace(/\D/g, "")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            Falar no WhatsApp
          </a>
        </div>
      </section>
    </div>
  </main>

  <script>
    const params = new URLSearchParams(window.location.search);
    const uid = params.get("uid")?.trim() || "-";
    const city = params.get("city")?.trim() || "-";
    const start = params.get("start")?.trim() || "";
    const statusRaw = params.get("status")?.trim() || "";

    const uidEl = document.getElementById("pending-booking-uid");
    const cityEl = document.getElementById("pending-booking-city");
    const startEl = document.getElementById("pending-booking-start");
    const statusEl = document.getElementById("pending-booking-status");

    if (uidEl) uidEl.textContent = uid;
    if (cityEl) cityEl.textContent = city;

    if (startEl) {
      if (!start) {
        startEl.textContent = "-";
      } else {
        const date = new Date(start);
        startEl.textContent = Number.isNaN(date.getTime())
          ? start
          : new Intl.DateTimeFormat("pt-BR", {
              day: "2-digit",
              month: "2-digit",
              year: "numeric",
              hour: "2-digit",
              minute: "2-digit",
            }).format(date);
      }
    }

    if (statusEl) {
      const normalized = statusRaw.toLowerCase();
      statusEl.textContent = normalized.includes("pending")
        ? "Pendente de pagamento"
        : statusRaw || "Pendente de pagamento";
    }
  </script>

  <Footer />
  <WhatsAppFloat client:idle />
</Layout>
