---
import ArticleFAQ from "@/components/ArticleFAQ";
import ArticleShareButtons from "@/components/ArticleShareButtons";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { LentesPremiumScrollHero } from "@/components/LentesPremiumScrollHero";
import { PresbiopiaScrollHero } from "@/components/PresbiopiaScrollHero";
import ScheduleConsultationSection from "@/components/ScheduleConsultationSection.astro";
import { siteConfig } from "@/config/site";
import { formatLastReviewedPtBr } from "@/lib/format-last-reviewed";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { stripFaqAnswerMarkdownForPlainText } from "@/lib/faq-answer-markdown";

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection("conteudos");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const {
  title,
  description,
  keywords,
  condition,
  procedure,
  readingTime,
  lastReviewed,
  faq,
  relatedSlugs,
  isOpinion,
  conflictOfInterest,
  conflictOfInterestNote,
} = article.data;

const lastReviewedFormatted = formatLastReviewedPtBr(lastReviewed);

const canonical = new URL(`/conteudos/${article.id}`, siteConfig.canonical).href;

const allArticles = await getCollection("conteudos");
const relatedArticles = allArticles.filter((a) => relatedSlugs.includes(a.id));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: siteConfig.canonical },
    {
      "@type": "ListItem",
      position: 2,
      name: "Conteúdos",
      item: new URL("/conteudos", siteConfig.canonical).href,
    },
    { "@type": "ListItem", position: 3, name: title, item: canonical },
  ],
};

const medicalPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: title,
  description,
  url: canonical,
  inLanguage: "pt-BR",
  isPartOf: {
    "@type": "WebSite",
    name: `${siteConfig.name} · ${siteConfig.title}`,
    url: siteConfig.canonical,
  },
  about: {
    "@type": "MedicalCondition",
    name: condition,
    possibleTreatment: procedure ? { "@type": "MedicalTherapy", name: procedure } : undefined,
  },
  audience: {
    "@type": "PeopleAudience",
    healthCondition: { "@type": "MedicalCondition", name: condition },
  },
  lastReviewed,
  reviewedBy: {
    "@type": "Physician",
    name: siteConfig.name,
    url: siteConfig.canonical,
  },
  specialty: { "@type": "MedicalSpecialty", name: "Ophthalmology" },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: stripFaqAnswerMarkdownForPlainText(item.answer),
    },
  })),
};

const allSchemas = [breadcrumbSchema, medicalPageSchema, faqSchema];

const articleSection =
  article.data.hubCategory === "exams"
    ? "Exames e procedimentos"
    : article.data.hubCategory === "refractive"
      ? "Erros refracionais e refração"
      : "Doenças e condições oculares";

const isPresbiopia = article.id === "presbiopia";
const isLentesPremium = article.id === "lentes-premium-catarata";
const hasScrollHero = isPresbiopia || isLentesPremium;

const scheduleSectionTitle = isLentesPremium
  ? "Planeje a lente da catarata na consulta"
  : "Agende sua Consulta Oftalmológica";
const scheduleSectionDescription = isLentesPremium
  ? "Discuta multifocal, EDoF, tórica e expectativas realistas com base nos seus exames. Agende online com horário escolhido ou fale pelo WhatsApp — sem compromisso com um modelo de lente antes da avaliação."
  : `Tem dúvidas sobre ${condition.toLowerCase()}? Agende uma consulta oftalmológica para avaliação completa e orientação personalizada.`;
const scheduleWhatsappTemplate = isLentesPremium
  ? "Olá! Gostaria de agendar consulta para avaliar opções de lente intraocular (multifocal, EDoF, tórica) na cirurgia de catarata em {city}."
  : `Olá! Gostaria de agendar uma consulta sobre ${condition.toLowerCase()} em {city}.`;
---

<Layout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  keywords={keywords}
  ogType="article"
  articleSection={articleSection}
>
  {
    allSchemas.map((schema) => (
      <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }
  <meta slot="head" name="subject" content={condition} />
  <meta slot="head" name="topic" content={`Oftalmologia - ${condition}`} />
  <meta slot="head" name="classification" content="Health" />
  <meta slot="head" name="category" content="Saúde - Oftalmologia" />

  <Header />

  {isPresbiopia && (
    <PresbiopiaScrollHero
      client:load
      title={title}
      description={description}
      readingTime={readingTime}
      lastReviewedFormatted={lastReviewedFormatted}
      isOpinion={isOpinion}
    />
  )}
  {isLentesPremium && (
    <LentesPremiumScrollHero
      client:load
      title={title}
      description={description}
      readingTime={readingTime}
      lastReviewedFormatted={lastReviewedFormatted}
      isOpinion={isOpinion}
    />
  )}

  <main
    id="conteudo-principal"
    tabindex="-1"
    class:list={[
      "mx-auto max-w-3xl px-4 sm:px-6",
      hasScrollHero
        ? isLentesPremium
          ? "pb-12 pt-16 sm:pt-20 md:pt-24"
          : "pb-12 pt-12 sm:pt-14 md:pt-16"
        : "py-12",
    ]}
  >
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li><a href="/" class="transition-colors hover:text-foreground">Início</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><a href="/conteudos" class="transition-colors hover:text-foreground">Conteúdos</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><span class="font-medium text-foreground" aria-current="page">{condition}</span></li>
      </ol>
    </nav>

    <article class="flex flex-col">
      {
        !hasScrollHero && (
          <header class="mb-8 space-y-3">
            <div class="flex flex-wrap items-center gap-2 sm:gap-3">
              <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2.5 py-0.5 text-xs font-medium text-brand">
                {readingTime} de leitura
              </span>
              <span class="inline-flex items-center rounded-full border border-border/60 bg-muted/40 px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
                Última revisão: {lastReviewedFormatted}
              </span>
              {isOpinion && (
                <span class="inline-flex items-center rounded-full border border-amber-500/35 bg-amber-500/10 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:text-amber-200">
                  Opinião
                </span>
              )}
            </div>
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h1>
            <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
              {description}
            </p>
          </header>
        )
      }

      <div class="mb-10 flex flex-col gap-5 sm:mb-12 sm:gap-6">
        {
          conflictOfInterest && (
            <aside
              class="not-prose rounded-md border border-border/50 bg-muted/20 px-3 py-2 text-xs leading-relaxed text-muted-foreground"
              aria-label="Declaração de conflito de interesses"
            >
              {conflictOfInterest === "none" ? (
                <p class="m-0">Sem conflito de interesses declarado em relação a este conteúdo.</p>
              ) : (
                <div class="space-y-1">
                  <p class="m-0 font-medium text-foreground/80">Conflito de interesses declarado.</p>
                  {conflictOfInterestNote ? (
                    <p class="m-0 text-muted-foreground">{conflictOfInterestNote}</p>
                  ) : null}
                </div>
              )}
            </aside>
          )
        }
        <div class="prose-article">
          <Content />
        </div>
        <ArticleShareButtons client:visible url={canonical} title={title} articleId={article.id} />
      </div>

      <section class="space-y-6" id="perguntas-frequentes">
        <h2 class="text-xl font-bold tracking-tight sm:text-2xl">Perguntas Frequentes</h2>
        <ArticleFAQ client:visible items={faq} />
      </section>

      <ScheduleConsultationSection
        class="mt-10"
        id="agendar"
        title={scheduleSectionTitle}
        description={scheduleSectionDescription}
        whatsappMessageTemplate={scheduleWhatsappTemplate}
        triggerLabel="Agendar consulta"
        triggerGtmId={`gtm-artigo-${article.id}-schedule-whatsapp`}
        agendaLinkGtmId={`gtm-artigo-${article.id}-schedule-agenda`}
        onlineBookingLinkId={`gtm-artigo-${article.id}-dialog-agendar-online`}
      />

      <footer class="mt-10 space-y-6 border-t border-border pt-8">
        <div class="mx-auto max-w-2xl rounded-xl border border-amber-500/20 bg-amber-500/5 p-4">
          <p class="text-center text-xs leading-relaxed text-muted-foreground">
            <strong>Aviso médico:</strong> Este conteúdo é informativo e educacional. Não substitui a
            consulta com um médico oftalmologista. Para diagnóstico e tratamento, procure atendimento
            profissional.
          </p>
        </div>

        {
          relatedArticles.length > 0 && (
            <div class="space-y-3">
              <h3 class="text-sm font-semibold text-foreground">Leia também</h3>
              <div class="flex flex-wrap gap-2">
                {relatedArticles.map((related) => (
                  <a
                    href={`/conteudos/${related.id}`}
                    class="rounded-md border border-border px-3 py-1.5 text-xs font-medium text-muted-foreground transition-colors hover:border-brand/40 hover:text-brand"
                  >
                    {related.data.condition}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </footer>
    </article>
  </main>

  <Footer />
</Layout>
