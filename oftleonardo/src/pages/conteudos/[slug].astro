---
import ArticleFAQ from "@/components/ArticleFAQ";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import ScheduleConsultationSection from "@/components/ScheduleConsultationSection.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection("conteudos");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, description, keywords, condition, procedure, readingTime, faq, relatedSlugs } =
  article.data;

const canonical = new URL(`/conteudos/${article.id}`, siteConfig.canonical).href;

const allArticles = await getCollection("conteudos");
const relatedArticles = allArticles.filter((a) => relatedSlugs.includes(a.id));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: siteConfig.canonical },
    {
      "@type": "ListItem",
      position: 2,
      name: "Conteúdos",
      item: new URL("/conteudos", siteConfig.canonical).href,
    },
    { "@type": "ListItem", position: 3, name: title, item: canonical },
  ],
};

const medicalPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: title,
  description,
  url: canonical,
  inLanguage: "pt-BR",
  isPartOf: {
    "@type": "WebSite",
    name: `${siteConfig.name} · ${siteConfig.title}`,
    url: siteConfig.canonical,
  },
  about: {
    "@type": "MedicalCondition",
    name: condition,
    possibleTreatment: procedure ? { "@type": "MedicalTherapy", name: procedure } : undefined,
  },
  audience: {
    "@type": "PeopleAudience",
    healthCondition: { "@type": "MedicalCondition", name: condition },
  },
  lastReviewed: new Date().toISOString().split("T")[0],
  reviewedBy: {
    "@type": "Physician",
    name: siteConfig.name,
    url: siteConfig.canonical,
  },
  specialty: { "@type": "MedicalSpecialty", name: "Ophthalmology" },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};

const allSchemas = [breadcrumbSchema, medicalPageSchema, faqSchema];

const articleSection =
  article.data.hubCategory === "exams" ? "Exames e procedimentos" : "Doenças, refração e cirurgia";
---

<Layout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  keywords={keywords}
  ogType="article"
  articleSection={articleSection}
>
  {
    allSchemas.map((schema) => (
      <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }
  <meta slot="head" name="subject" content={condition} />
  <meta slot="head" name="topic" content={`Oftalmologia - ${condition}`} />
  <meta slot="head" name="classification" content="Health" />
  <meta slot="head" name="category" content="Saúde - Oftalmologia" />

  <Header />

  <main id="conteudo-principal" tabindex="-1" class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li><a href="/" class="transition-colors hover:text-foreground">Início</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><a href="/conteudos" class="transition-colors hover:text-foreground">Conteúdos</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><span class="font-medium text-foreground" aria-current="page">{condition}</span></li>
      </ol>
    </nav>

    <article class="space-y-10">
      <header class="space-y-3">
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2.5 py-0.5 text-xs font-medium text-brand">
            {readingTime} de leitura
          </span>
        </div>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h1>
        <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
          {description}
        </p>
      </header>

      <div class="prose-article">
        <Content />
      </div>

      <section class="space-y-6" id="perguntas-frequentes">
        <h2 class="text-xl font-bold tracking-tight sm:text-2xl">Perguntas Frequentes</h2>
        <ArticleFAQ client:visible items={faq} />
      </section>

      <ScheduleConsultationSection
        id="agendar"
        title="Agende sua Consulta Oftalmológica"
        description={`Tem dúvidas sobre ${condition.toLowerCase()}? Agende uma consulta com Leonardo Nunes para avaliação completa e orientação personalizada.`}
        whatsappMessageTemplate={`Olá, Dr. Leonardo! Gostaria de agendar uma consulta sobre ${condition.toLowerCase()} em {city}.`}
        triggerLabel="Agendar consulta"
        triggerGtmId={`gtm-artigo-${article.id}-schedule-whatsapp`}
        agendaLinkGtmId={`gtm-artigo-${article.id}-schedule-agenda`}
        onlineBookingLinkId={`gtm-artigo-${article.id}-dialog-agendar-online`}
      />

      <footer class="space-y-6 border-t border-border pt-8">
        <div class="mx-auto max-w-2xl rounded-lg border border-amber-500/20 bg-amber-500/5 p-4">
          <p class="text-center text-xs leading-relaxed text-muted-foreground">
            <strong>Aviso médico:</strong> Este conteúdo é informativo e educacional. Não substitui a
            consulta com um médico oftalmologista. Para diagnóstico e tratamento, procure atendimento
            profissional.
          </p>
        </div>

        {
          relatedArticles.length > 0 && (
            <div class="space-y-3">
              <h3 class="text-sm font-semibold text-foreground">Conteúdos relacionados</h3>
              <div class="flex flex-wrap gap-2">
                {relatedArticles.map((related) => (
                  <a
                    href={`/conteudos/${related.id}`}
                    class="rounded-lg border border-border px-3 py-1.5 text-xs font-medium text-muted-foreground transition-colors hover:border-brand/40 hover:text-brand"
                  >
                    {related.data.condition}
                  </a>
                ))}
              </div>
            </div>
          )
        }

        <nav
          aria-label="Links relacionados"
          class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-muted-foreground"
        >
          <a href="/" class="transition-colors hover:text-foreground">Página Inicial</a>
          <a href="/conteudos" class="transition-colors hover:text-foreground">Hub de Conteúdos</a>
          <a href="/#atuacao" class="transition-colors hover:text-foreground">Especialidades</a>
          <a href="/#atendimento" class="transition-colors hover:text-foreground">Cidades de Atendimento</a>
          <a href="/acuidade-visual" class="transition-colors hover:text-foreground">Teste de Acuidade Visual</a>
          <a href="/tela-de-amsler" class="transition-colors hover:text-foreground">Tela de Amsler</a>
        </nav>
      </footer>
    </article>
  </main>

  <Footer />
</Layout>
