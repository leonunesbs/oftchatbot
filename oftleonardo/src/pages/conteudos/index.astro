---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { clusterTopics } from "@/config/semantic-clusters";
import { buttonVariants } from "@/components/ui/button";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

const articles = await getCollection("conteudos");
const conditionArticles = articles.filter((a) => a.data.hubCategory === "conditions");
const conditionArticlesSorted = [...conditionArticles].sort((a, b) =>
  a.data.condition.localeCompare(b.data.condition, "pt-BR"),
);
const refractiveArticles = articles.filter((a) => a.data.hubCategory === "refractive");
const refractiveArticlesSorted = [...refractiveArticles].sort((a, b) =>
  a.data.condition.localeCompare(b.data.condition, "pt-BR"),
);
const examArticles = articles.filter((a) => a.data.hubCategory === "exams");
const examArticlesSorted = [...examArticles].sort((a, b) => {
  if (a.id === "exames-oftalmologicos") return -1;
  if (b.id === "exames-oftalmologicos") return 1;
  return a.data.condition.localeCompare(b.data.condition, "pt-BR");
});
const tools = clusterTopics.filter((t) => t.intent === "informational");
const scheduling = clusterTopics.find((t) => t.intent === "transactional");

const hubSections = [
  conditionArticlesSorted.length > 0 && {
    id: "doencas-e-condicoes",
    label: "Doenças e condições",
  },
  refractiveArticlesSorted.length > 0 && {
    id: "erros-refracionais",
    label: "Erros refracionais e refração",
  },
  examArticlesSorted.length > 0 && {
    id: "exames-e-diagnostico",
    label: "Exames e diagnóstico",
  },
  tools.length > 0 && {
    id: "ferramentas-de-triagem",
    label: "Ferramentas de triagem",
  },
  scheduling && {
    id: "agendar-consulta",
    label: "Agendar consulta",
  },
].filter(Boolean) as { id: string; label: string }[];

const title = "Conteúdos de Oftalmologia | Retina, Catarata e Triagem Visual";
const description =
  "Hub de conteúdos de oftalmologia com guias sobre doenças oculares, erros de refração (miopia, astigmatismo, presbiopia etc.), exames (OCT, campo visual, topografia, angiografia), triagem visual e agendamento.";
const canonical = new URL("/conteudos", siteConfig.canonical).href;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: siteConfig.canonical },
    { "@type": "ListItem", position: 2, name: "Conteúdos", item: canonical },
  ],
};

const schemaItems = [
  ...tools.map((t) => ({ title: t.title, href: t.href, condition: t.condition })),
  ...articles.map((a) => ({
    title: a.data.title,
    href: `/conteudos/${a.id}`,
    condition: a.data.condition,
  })),
  ...(scheduling ? [{ title: scheduling.title, href: scheduling.href, condition: undefined }] : []),
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Conteúdos de Oftalmologia",
  itemListElement: schemaItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.title,
    url: new URL(item.href, siteConfig.canonical).href,
  })),
};

const conditionSchemas = schemaItems
  .filter((item) => Boolean(item.condition))
  .map((item) => ({
    "@context": "https://schema.org",
    "@type": "MedicalCondition",
    name: item.condition,
  }));

const allSchemas = [breadcrumbSchema, itemListSchema, ...conditionSchemas];
---

<Layout title={title} description={description} ogType="article">
  {
    allSchemas.map((schema) => (
      <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }

  <Header />
  <main id="conteudo-principal" tabindex="-1" class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li><a href="/" class="transition-colors hover:text-foreground">Início</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><span class="font-medium text-foreground" aria-current="page">Conteúdos</span></li>
      </ol>
    </nav>

    <section class="rounded-2xl border border-border/60 bg-card p-6 sm:p-8">
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Hub de Conteúdos em Oftalmologia</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
        Explore guias sobre doenças oculares e erros de refração, referências sobre exames (diagnóstico
        por imagem e função visual) e ferramentas de triagem. Informações acessíveis revisadas por
        Leonardo Nunes,
        oftalmologista especialista em retina e catarata.
      </p>
    </section>

    {
      hubSections.length > 0 && (
        <nav
          aria-label="Seções desta página"
          class="mt-8 rounded-2xl border border-dashed border-border/80 bg-muted/30 p-4 sm:p-5"
        >
          <p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Nesta página</p>
          <ul class="mt-3 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:gap-x-4 sm:gap-y-2">
            {hubSections.map((s) => (
              <li>
                <a
                  href={`#${s.id}`}
                  class="inline-flex items-center gap-1.5 text-sm font-medium text-foreground underline-offset-4 transition-colors hover:text-brand hover:underline"
                >
                  <span aria-hidden="true" class="text-muted-foreground">
                    →
                  </span>
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    {
      conditionArticlesSorted.length > 0 && (
        <section
          id="doencas-e-condicoes"
          aria-labelledby="heading-doencas"
          class="scroll-mt-28 mt-12 rounded-2xl border border-border/60 border-l-4 border-l-sky-500/55 bg-sky-500/[0.04] p-6 shadow-sm sm:p-8 dark:bg-sky-500/[0.06]"
        >
          <header class="border-b border-border/50 pb-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-sky-700 dark:text-sky-400">
              Guias clínicos
            </p>
            <h2 id="heading-doencas" class="mt-1 text-xl font-semibold tracking-tight text-foreground sm:text-2xl">
              Doenças e condições oculares
            </h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted-foreground">
              Textos sobre sintomas, causas e opções de tratamento — material educativo, não substitui
              avaliação presencial.
            </p>
          </header>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {conditionArticlesSorted.map((article) => (
              <article class="group rounded-xl border border-border/60 bg-card p-5 transition-colors hover:border-sky-500/35">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full border border-sky-500/25 bg-sky-500/10 px-2 py-0.5 text-[10px] font-medium text-sky-700 dark:text-sky-400">
                    Guia
                  </span>
                  <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2 py-0.5 text-[10px] font-medium text-brand">
                    {article.data.readingTime}
                  </span>
                </div>
                <h3 class="mt-2 text-base font-semibold text-foreground">{article.data.condition}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground line-clamp-2">
                  {article.data.description}
                </p>
                <a
                  href={`/conteudos/${article.id}`}
                  class="mt-3 inline-flex text-sm font-medium text-brand hover:underline"
                >
                  Ler conteúdo
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      refractiveArticlesSorted.length > 0 && (
        <section
          id="erros-refracionais"
          aria-labelledby="heading-refracao"
          class="scroll-mt-28 mt-12 rounded-2xl border border-border/60 border-l-4 border-l-amber-500/55 bg-amber-500/[0.04] p-6 shadow-sm sm:p-8 dark:bg-amber-500/[0.06]"
        >
          <header class="border-b border-border/50 pb-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-800 dark:text-amber-400">
              Refração
            </p>
            <h2
              id="heading-refracao"
              class="mt-1 text-xl font-semibold tracking-tight text-foreground sm:text-2xl"
            >
              Erros refracionais e refração
            </h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted-foreground">
              Miopia, hipermetropia, astigmatismo, presbiopia e cirurgia refrativa — como entender o
              grau, sintomas e opções de correção.
            </p>
          </header>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {refractiveArticlesSorted.map((article) => (
              <article class="group rounded-xl border border-border/60 bg-card p-5 transition-colors hover:border-amber-500/40">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full border border-amber-500/25 bg-amber-500/10 px-2 py-0.5 text-[10px] font-medium text-amber-800 dark:text-amber-400">
                    Refração
                  </span>
                  <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2 py-0.5 text-[10px] font-medium text-brand">
                    {article.data.readingTime}
                  </span>
                </div>
                <h3 class="mt-2 text-base font-semibold text-foreground">{article.data.condition}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground line-clamp-2">
                  {article.data.description}
                </p>
                <a
                  href={`/conteudos/${article.id}`}
                  class="mt-3 inline-flex text-sm font-medium text-brand hover:underline"
                >
                  Ler conteúdo
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      examArticlesSorted.length > 0 && (
        <section
          id="exames-e-diagnostico"
          aria-labelledby="heading-exames"
          class="scroll-mt-28 mt-12 rounded-2xl border border-border/60 border-l-4 border-l-violet-500/55 bg-violet-500/[0.04] p-6 shadow-sm sm:p-8 dark:bg-violet-500/[0.06]"
        >
          <header class="border-b border-border/50 pb-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-violet-700 dark:text-violet-400">
              Referências sobre exames
            </p>
            <h2 id="heading-exames" class="mt-1 text-xl font-semibold tracking-tight text-foreground sm:text-2xl">
              Exames e diagnóstico
            </h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted-foreground">
              O que cada procedimento avalia, como costuma ser feito e em que contexto o oftalmologista
              pode indicá-lo.
            </p>
          </header>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {examArticlesSorted.map((article) => (
              <article class="group rounded-xl border border-border/60 bg-card p-5 transition-colors hover:border-violet-500/35">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full border border-violet-500/20 bg-violet-500/10 px-2 py-0.5 text-[10px] font-medium text-violet-600 dark:text-violet-400">
                    Referência
                  </span>
                  <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2 py-0.5 text-[10px] font-medium text-brand">
                    {article.data.readingTime}
                  </span>
                </div>
                <h3 class="mt-2 text-base font-semibold text-foreground">{article.data.condition}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground line-clamp-2">
                  {article.data.description}
                </p>
                <a
                  href={`/conteudos/${article.id}`}
                  class="mt-3 inline-flex text-sm font-medium text-brand hover:underline"
                >
                  Ler conteúdo
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      tools.length > 0 && (
        <section
          id="ferramentas-de-triagem"
          aria-labelledby="heading-ferramentas"
          class="scroll-mt-28 mt-12 rounded-2xl border border-border/60 border-l-4 border-l-emerald-500/55 bg-emerald-500/[0.04] p-6 shadow-sm sm:p-8 dark:bg-emerald-500/[0.06]"
        >
          <header class="border-b border-border/50 pb-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700 dark:text-emerald-400">
              Interativo
            </p>
            <h2 id="heading-ferramentas" class="mt-1 text-xl font-semibold tracking-tight text-foreground sm:text-2xl">
              Ferramentas de triagem visual
            </h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted-foreground">
              Testes rápidos no navegador para orientação — não substituem exame clínico nem laudo
              médico.
            </p>
          </header>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {tools.map((tool) => (
              <article class="group rounded-xl border border-border/60 bg-card p-5 transition-colors hover:border-emerald-500/35">
                <span class="inline-flex items-center rounded-full border border-emerald-500/20 bg-emerald-500/10 px-2 py-0.5 text-[10px] font-medium text-emerald-600 dark:text-emerald-400">
                  Ferramenta
                </span>
                <h3 class="mt-2 text-base font-semibold text-foreground">{tool.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{tool.description}</p>
                <a
                  href={tool.href}
                  class="mt-3 inline-flex text-sm font-medium text-brand hover:underline"
                >
                  Acessar ferramenta
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      scheduling && (
        <section id="agendar-consulta" aria-labelledby="heading-agendar" class="scroll-mt-28 mt-12">
          <a
            href={scheduling.href}
            class="group flex flex-col items-center gap-3 rounded-2xl border border-brand/30 border-l-4 border-l-brand bg-brand/5 p-6 text-center transition-colors hover:border-brand/50 hover:bg-brand/10 sm:p-8"
          >
            <header>
              <p class="text-xs font-semibold uppercase tracking-wide text-brand">Próximo passo</p>
              <h2 id="heading-agendar" class="mt-1 text-lg font-semibold text-foreground sm:text-xl">
                {scheduling.title}
              </h2>
            </header>
            <p class="max-w-lg text-sm leading-relaxed text-muted-foreground">{scheduling.description}</p>
            <span
              class={`${buttonVariants({ size: "lg" })} px-8 text-base transition-transform group-hover:scale-105`}
            >
              Agendar consulta
            </span>
          </a>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>
