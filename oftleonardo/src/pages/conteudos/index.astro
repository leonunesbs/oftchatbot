---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { clusterTopics } from "@/config/semantic-clusters";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

const articles = await getCollection("conteudos");

const title = "Conteúdos de Oftalmologia | Retina, Catarata e Triagem Visual";
const description =
  "Hub de conteúdos de oftalmologia com guias sobre retinopatia diabética, DMRI, glaucoma, catarata, ceratocone, estrabismo, triagem visual e agendamento de consulta.";
const canonical = new URL("/conteudos", siteConfig.canonical).href;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: siteConfig.canonical },
    { "@type": "ListItem", position: 2, name: "Conteúdos", item: canonical },
  ],
};

const allItems = [
  ...clusterTopics.map((topic) => ({
    title: topic.title,
    description: topic.description,
    href: topic.href,
    intent: topic.intent,
    condition: topic.condition,
  })),
  ...articles.map((article) => ({
    title: article.data.title,
    description: article.data.description,
    href: `/conteudos/${article.id}`,
    intent: "informational" as const,
    condition: article.data.condition,
  })),
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Conteúdos de Oftalmologia",
  itemListElement: allItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.title,
    url: new URL(item.href, siteConfig.canonical).href,
  })),
};

const conditionSchemas = allItems
  .filter((item) => Boolean(item.condition))
  .map((item) => ({
    "@context": "https://schema.org",
    "@type": "MedicalCondition",
    name: item.condition,
  }));

const allSchemas = [breadcrumbSchema, itemListSchema, ...conditionSchemas];
---

<Layout title={title} description={description} ogType="article">
  {
    allSchemas.map((schema) => (
      <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }

  <Header />
  <main id="conteudo-principal" tabindex="-1" class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li><a href="/" class="transition-colors hover:text-foreground">Início</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><span class="font-medium text-foreground" aria-current="page">Conteúdos</span></li>
      </ol>
    </nav>

    <section class="rounded-2xl border border-border/60 bg-card p-6 sm:p-8">
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Hub de Conteúdos em Oftalmologia</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
        Explore conteúdos sobre doenças oculares, ferramentas de triagem visual e agendamento.
        Informações acessíveis revisadas por Leonardo Nunes, oftalmologista especialista em retina e
        catarata.
      </p>
    </section>

    {
      articles.length > 0 && (
        <section class="mt-8">
          <h2 class="mb-4 text-lg font-semibold text-foreground">Doenças e Condições Oculares</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {articles.map((article) => (
              <article class="group rounded-xl border border-border/60 bg-card p-5 transition-colors hover:border-brand/30">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2 py-0.5 text-[10px] font-medium text-brand">
                    {article.data.readingTime}
                  </span>
                  <span class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground">
                    Informacional
                  </span>
                </div>
                <h3 class="mt-2 text-base font-semibold text-foreground">{article.data.condition}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground line-clamp-2">
                  {article.data.description}
                </p>
                <a
                  href={`/conteudos/${article.id}`}
                  class="mt-3 inline-flex text-sm font-medium text-brand hover:underline"
                >
                  Ler conteúdo
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-8">
      <h2 class="mb-4 text-lg font-semibold text-foreground">Ferramentas e Agendamento</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          clusterTopics.map((topic) => (
            <article class="group rounded-xl border border-border/60 bg-card p-5 transition-colors hover:border-brand/30">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-brand">
                {topic.intent === "transactional" ? "Transacional" : "Informacional"}
              </p>
              <h3 class="mt-2 text-base font-semibold text-foreground">{topic.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{topic.description}</p>
              <a href={topic.href} class="mt-3 inline-flex text-sm font-medium text-brand hover:underline">
                Abrir conteúdo
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
