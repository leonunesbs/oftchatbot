---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import WhatsAppFloat from "@/components/WhatsAppFloat";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

const title = "Agendamento Online | Leonardo Nunes · Oftalmologista";
const description =
  "Agende sua consulta oftalmológica online com praticidade, escolha o melhor horário e conclua o pagamento com segurança.";
const keywords =
  "agendamento online oftalmologista, consulta oftalmológica online, agendar consulta retina, agendar consulta catarata";
const canonical = new URL("/agendamento-online", siteConfig.canonical).href;

const faqItems = [
  {
    question: "Como funciona o agendamento online da consulta oftalmológica?",
    answer:
      "Selecione sua cidade de atendimento e escolha um horário disponível. Ao confirmar, você é redirecionado para o pagamento seguro via Stripe.",
  },
  {
    question: "Posso agendar consulta de retina e catarata online?",
    answer:
      "Sim. O agendamento online é válido para consulta oftalmológica completa, incluindo avaliação de retina, catarata e outras queixas visuais. A definição do plano de cuidado é feita durante a consulta médica.",
  },
  {
    question: "Se eu não encontrar horário, posso agendar por WhatsApp?",
    answer:
      "Sim. Caso não haja horário disponível no momento, você pode continuar o agendamento pelo WhatsApp da cidade selecionada para verificar encaixes e outras possibilidades.",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Início",
      item: siteConfig.canonical,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Agendamento Online",
      item: canonical,
    },
  ],
};

const medicalWebPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: "Agendamento Online de Consulta Oftalmológica",
  description,
  url: canonical,
  mainEntityOfPage: canonical,
  inLanguage: "pt-BR",
  specialty: {
    "@type": "MedicalSpecialty",
    name: "Ophthalmology",
  },
  about: {
    "@type": "MedicalProcedure",
    name: "Consulta Oftalmológica",
  },
  mainEntity: {
    "@type": "Physician",
    name: siteConfig.name,
    medicalSpecialty: "Ophthalmology",
    url: siteConfig.canonical,
    telephone: siteConfig.phone,
  },
  potentialAction: {
    "@type": "ReserveAction",
    name: "Agendar consulta oftalmológica",
    target: {
      "@type": "EntryPoint",
      urlTemplate: siteConfig.partnerApps.oftagenda,
      inLanguage: "pt-BR",
      actionPlatform: [
        "https://schema.org/DesktopWebPlatform",
        "https://schema.org/MobileWebPlatform",
      ],
    },
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const allSchemas = [breadcrumbSchema, medicalWebPageSchema, faqSchema];
---

<Layout title={title} description={description} keywords={keywords}>
  {
    allSchemas.map((schema) => (
      <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    ))
  }
  <meta slot="head" name="subject" content="Agendamento Online Oftalmológico" />
  <meta
    slot="head"
    name="topic"
    content="Consulta Oftalmológica - Agendamento"
  />
  <meta slot="head" name="classification" content="Health" />
  <meta slot="head" name="category" content="Saúde - Oftalmologia" />

  <Header />

  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative isolate overflow-x-clip"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(45%_35%_at_10%_15%,color-mix(in_oklch,var(--color-brand)_10%,transparent),transparent),radial-gradient(35%_30%_at_90%_85%,color-mix(in_oklch,var(--color-brand)_8%,transparent),transparent)]"
      aria-hidden="true"
    >
    </div>

    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1 text-xs text-muted-foreground">
          <li>
            <a href="/" class="transition-colors hover:text-foreground"
              >Início</a
            >
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li>
            <span class="font-medium text-foreground" aria-current="page"
              >Agendamento Online</span
            >
          </li>
        </ol>
      </nav>

      <section
        class="rounded-2xl border border-border/50 bg-card p-6 shadow-sm sm:p-8"
      >
        <div class="max-w-3xl">
          <p
            class="inline-flex rounded-full border border-brand/20 bg-brand/10 px-3 py-1 text-xs font-semibold tracking-wide text-brand"
          >
            Agendamento online
          </p>
          <h1
            class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
          >
            Agende sua consulta oftalmológica online com rapidez e segurança
          </h1>
          <p
            class="mt-4 text-sm leading-relaxed text-muted-foreground sm:text-base"
          >
            Escolha a cidade de atendimento, selecione um horário disponível e
            conclua seu agendamento online em poucos passos. O pagamento é
            processado com segurança via Stripe. Atendimento em retina, catarata
            e oftalmologia clínica com abordagem humanizada.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span
              class="rounded-full border border-border/60 bg-secondary/40 px-3 py-1 text-xs font-medium text-foreground"
            >
              Atendimento humanizado
            </span>
            <span
              class="rounded-full border border-border/60 bg-secondary/40 px-3 py-1 text-xs font-medium text-foreground"
            >
              Especialista em retina e catarata
            </span>
            <span
              class="rounded-full border border-border/60 bg-secondary/40 px-3 py-1 text-xs font-medium text-foreground"
            >
              Confirmação rápida
            </span>
          </div>
        </div>
      </section>

      <section class="mt-8">
        <div
          class="rounded-2xl border border-border/50 bg-card p-6 shadow-sm sm:p-8"
        >
          <h2 class="text-xl font-bold tracking-tight text-foreground sm:text-2xl">
            Iniciar agendamento
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
            Clique no botao abaixo para continuar no sistema de agendamento e
            escolher cidade, data e horario da sua consulta.
          </p>
          <a
            href={siteConfig.partnerApps.oftagenda}
            class="mt-6 inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
            aria-label="Ir para a pagina de agendamento"
          >
            Agendar consulta
          </a>
        </div>
      </section>

      <section class="mt-12">
        <h2
          class="text-xl font-bold tracking-tight text-foreground sm:text-2xl"
        >
          Dúvidas frequentes
        </h2>
        <dl class="mt-6 space-y-6">
          {
            faqItems.map((item) => (
              <div>
                <dt class="text-sm font-semibold text-foreground">
                  {item.question}
                </dt>
                <dd class="mt-2 text-sm text-muted-foreground">{item.answer}</dd>
              </div>
            ))
          }
        </dl>
      </section>
    </div>
  </main>

  <Footer />
  <WhatsAppFloat client:idle />
</Layout>
