---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import BookingDatePicker from "@/components/BookingDatePicker";
import WhatsAppFloat from "@/components/WhatsAppFloat";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

const title = "Agendamento Online | Leonardo Nunes · Oftalmologista";
const description =
  "Agende sua consulta oftalmológica online com praticidade, escolha o melhor horário e receba por e-mail o link para concluir o pagamento.";
const keywords =
  "agendamento online oftalmologista, consulta oftalmológica online, cal.com, agendar consulta retina, agendar consulta catarata";
const canonical = new URL("/agendamento-online", siteConfig.canonical).href;
const defaultWhatsappNumber = siteConfig.phone.replace(/\D/g, "");

const faqItems = [
  {
    question: "Como funciona o agendamento online da consulta oftalmológica?",
    answer:
      "Selecione sua cidade de atendimento, preencha seus dados e escolha um horário disponível. Ao confirmar, seu agendamento é criado com pagamento pendente e você recebe por e-mail o link para concluir o pagamento.",
  },
  {
    question: "Posso agendar consulta de retina e catarata online?",
    answer:
      "Sim. O agendamento online é válido para consulta oftalmológica completa, incluindo avaliação de retina, catarata e outras queixas visuais. A definição do plano de cuidado é feita durante a consulta médica.",
  },
  {
    question: "Se eu não encontrar horário, posso agendar por WhatsApp?",
    answer:
      "Sim. Caso não haja horário disponível no momento, você pode continuar o agendamento pelo WhatsApp da cidade selecionada para verificar encaixes e outras possibilidades.",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Início",
      item: siteConfig.canonical,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Agendamento Online",
      item: canonical,
    },
  ],
};

const medicalWebPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: "Agendamento Online de Consulta Oftalmológica",
  description,
  url: canonical,
  mainEntityOfPage: canonical,
  inLanguage: "pt-BR",
  specialty: {
    "@type": "MedicalSpecialty",
    name: "Ophthalmology",
  },
  about: {
    "@type": "MedicalProcedure",
    name: "Consulta Oftalmológica",
  },
  mainEntity: {
    "@type": "Physician",
    name: siteConfig.name,
    medicalSpecialty: "Ophthalmology",
    url: siteConfig.canonical,
    telephone: siteConfig.phone,
  },
  potentialAction: {
    "@type": "ReserveAction",
    name: "Agendar consulta oftalmológica",
    target: {
      "@type": "EntryPoint",
      urlTemplate: canonical,
      inLanguage: "pt-BR",
      actionPlatform: [
        "https://schema.org/DesktopWebPlatform",
        "https://schema.org/MobileWebPlatform",
      ],
    },
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const allSchemas = [breadcrumbSchema, medicalWebPageSchema, faqSchema];
---

<Layout title={title} description={description} keywords={keywords}>
  {
    allSchemas.map((schema) => (
      <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    ))
  }
  <meta slot="head" name="subject" content="Agendamento Online Oftalmológico" />
  <meta
    slot="head"
    name="topic"
    content="Consulta Oftalmológica - Agendamento"
  />
  <meta slot="head" name="classification" content="Health" />
  <meta slot="head" name="category" content="Saúde - Oftalmologia" />

  <Header />

  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative isolate overflow-x-clip"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(45%_35%_at_10%_15%,color-mix(in_oklch,var(--color-brand)_10%,transparent),transparent),radial-gradient(35%_30%_at_90%_85%,color-mix(in_oklch,var(--color-brand)_8%,transparent),transparent)]"
      aria-hidden="true"
    >
    </div>

    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1 text-xs text-muted-foreground">
          <li>
            <a href="/" class="transition-colors hover:text-foreground"
              >Início</a
            >
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li>
            <span class="font-medium text-foreground" aria-current="page"
              >Agendamento Online</span
            >
          </li>
        </ol>
      </nav>

      <section
        class="rounded-2xl border border-border/50 bg-card p-6 shadow-sm sm:p-8"
      >
        <div class="max-w-3xl">
          <p
            class="inline-flex rounded-full border border-brand/20 bg-brand/10 px-3 py-1 text-xs font-semibold tracking-wide text-brand"
          >
            Agendamento online
          </p>
          <h1
            class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
          >
            Agende sua consulta oftalmológica online com rapidez e segurança
          </h1>
          <p
            class="mt-4 text-sm leading-relaxed text-muted-foreground sm:text-base"
          >
            Escolha a cidade de atendimento, selecione um horário disponível e
            conclua seu agendamento online em poucos passos. Após o agendamento,
            o pagamento permanece pendente e deve ser feito pelo link enviado no
            seu e-mail. Atendimento em retina, catarata e oftalmologia clínica
            com abordagem humanizada.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span
              class="rounded-full border border-border/60 bg-secondary/40 px-3 py-1 text-xs font-medium text-foreground"
            >
              Atendimento humanizado
            </span>
            <span
              class="rounded-full border border-border/60 bg-secondary/40 px-3 py-1 text-xs font-medium text-foreground"
            >
              Especialista em retina e catarata
            </span>
            <span
              class="rounded-full border border-border/60 bg-secondary/40 px-3 py-1 text-xs font-medium text-foreground"
            >
              Confirmação rápida
            </span>
          </div>
        </div>
      </section>

      <section class="mt-8 grid gap-6 lg:grid-cols-3">
        <div
          class="rounded-2xl border border-border/50 bg-card p-6 shadow-sm sm:p-8 lg:col-span-2"
        >
          <div class="mb-6">
            <h2
              class="text-xl font-bold tracking-tight text-foreground sm:text-2xl"
            >
              Dados para agendar
            </h2>
            <p class="mt-2 text-sm text-muted-foreground">
              Preencha seus dados e escolha um horário disponível para gerar seu
              agendamento.
            </p>
          </div>

          <form
            id="online-booking-form"
            class="space-y-6"
            aria-describedby="booking-form-guidance form-status"
          >
            <p id="booking-form-guidance" class="sr-only">
              Preencha nome completo, e-mail e telefone com DDD para liberar os
              horários disponíveis.
            </p>
            <div class="grid gap-5 sm:grid-cols-2">
              <fieldset
                class="sm:col-span-2"
                aria-describedby="city-selection-help"
              >
                <legend
                  id="city-selection-legend"
                  class="mb-2 text-sm font-medium text-foreground"
                  >Local</legend
                >
                <p id="city-selection-help" class="mb-2 text-xs text-muted-foreground">
                  Selecione a cidade de atendimento para carregar a agenda.
                </p>
                <div
                  id="city-options"
                  class="grid gap-2 sm:grid-cols-3"
                  aria-live="polite"
                  role="radiogroup"
                  aria-labelledby="city-selection-legend"
                >
                  {
                    Array.from({ length: 6 }).map(() => (
                      <div
                        class="h-10 rounded-md border border-border/50 bg-secondary/50 animate-pulse"
                        aria-hidden="true"
                      />
                    ))
                  }
                </div>
              </fieldset>

              <label class="flex flex-col gap-2 text-sm">
                <span class="font-medium text-foreground">Nome completo</span>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  minlength="3"
                  placeholder="Seu nome"
                  autocomplete="name"
                  enterkeyhint="next"
                  autocapitalize="words"
                  class="h-11 rounded-md border border-input bg-background px-3 text-base text-foreground shadow-xs transition-colors placeholder:text-muted-foreground focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/30"
                />
              </label>

              <label class="flex flex-col gap-2 text-sm">
                <span class="font-medium text-foreground">E-mail</span>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder="voce@email.com"
                  autocomplete="email"
                  enterkeyhint="next"
                  autocapitalize="off"
                  autocorrect="off"
                  spellcheck="false"
                  class="h-11 rounded-md border border-input bg-background px-3 text-base text-foreground shadow-xs transition-colors placeholder:text-muted-foreground focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/30"
                />
              </label>

              <label class="flex flex-col gap-2 text-sm">
                <span class="font-medium text-foreground">Telefone</span>
                <input
                  id="phoneNumber"
                  name="phoneNumber"
                  type="tel"
                  required
                  placeholder="(85) 99999-9999"
                  autocomplete="tel-national"
                  inputmode="numeric"
                  enterkeyhint="done"
                  maxlength="15"
                  aria-describedby="phone-help"
                  class="h-11 rounded-md border border-input bg-background px-3 text-base text-foreground shadow-xs transition-colors placeholder:text-muted-foreground focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/30"
                />
                <span id="phone-help" class="text-xs text-muted-foreground">
                  Aceita preenchimento automático com ou sem +55. O número será
                  ajustado automaticamente para o formato brasileiro.
                </span>
              </label>
            </div>

            <div
              id="slots-card"
              class="hidden rounded-xl border border-border/60 bg-secondary/30 p-4 sm:p-5"
            >
              <p class="text-sm font-semibold text-foreground">
                Data e horário
              </p>
              <p
                id="slots-help"
                aria-live="polite"
                role="status"
                class="mt-2 text-xs leading-relaxed text-muted-foreground"
              >
                Selecione um local para carregar os horários.
              </p>
              <fieldset class="mt-4">
                <legend
                  class="text-xs font-semibold uppercase tracking-wide text-muted-foreground"
                >
                  Janela de busca
                </legend>
                <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="current-week"
                      checked
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Semana atual
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="next-week"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Próxima semana
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="current-month"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Mês atual
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="next-month"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Próximo mês
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="current-year"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Esse ano
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="next-3-months"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Em 3 meses
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="next-6-months"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Em 6 meses
                    </span>
                  </label>
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="dateWindowPreset"
                      value="next-1-year"
                    />
                    <span
                      class="inline-flex h-9 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand"
                    >
                      Em 1 ano
                    </span>
                  </label>
                </div>
              </fieldset>
              <div class="mt-3">
                <BookingDatePicker client:idle />
                <input id="manual-date-input" type="hidden" />
              </div>
              <div
                id="slots-date-list"
                class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3"
              >
              </div>
              <div id="slots-time-list" class="mt-4 grid gap-2 sm:grid-cols-2">
              </div>
            </div>

            <input id="selectedStart" name="selectedStart" type="hidden" />
            <input id="timeZone" name="timeZone" type="hidden" />

            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <button
                id="submit-button"
                type="submit"
                class="inline-flex h-11 items-center justify-center rounded-md bg-primary px-6 text-base font-medium text-primary-foreground transition-all hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-50"
              >
                Agendar consulta
              </button>
              <p
                id="form-status"
                aria-live="polite"
                role="status"
                class="min-h-5 text-sm text-muted-foreground"
              >
              </p>
            </div>
          </form>
        </div>

        <aside class="space-y-6">
          <section
            class="rounded-2xl border border-border/50 bg-card p-5 shadow-sm sm:p-6"
          >
            <h2 class="text-base font-semibold text-foreground">
              Como funciona
            </h2>
            <ol class="mt-4 space-y-3 text-sm text-muted-foreground">
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 inline-flex size-6 shrink-0 items-center justify-center rounded-full border border-brand/30 bg-brand/10 text-xs font-semibold text-brand"
                >
                  1
                </span>
                <span>Selecione sua cidade de atendimento.</span>
              </li>
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 inline-flex size-6 shrink-0 items-center justify-center rounded-full border border-brand/30 bg-brand/10 text-xs font-semibold text-brand"
                >
                  2
                </span>
                <span>Escolha um horário disponível e informe seus dados.</span>
              </li>
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 inline-flex size-6 shrink-0 items-center justify-center rounded-full border border-brand/30 bg-brand/10 text-xs font-semibold text-brand"
                >
                  3
                </span>
                <span
                  >Conclua o pagamento pelo link enviado no e-mail para
                  confirmar a consulta.</span
                >
              </li>
            </ol>
          </section>

          <section
            class="rounded-2xl border border-border/50 bg-card p-5 shadow-sm sm:p-6"
          >
            <p class="text-sm font-semibold text-foreground">
              Prefere WhatsApp?
            </p>
            <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
              Você pode continuar com o fluxo principal por WhatsApp:
            </p>
            <div id="whatsapp-fallback-links" class="mt-4 flex flex-wrap gap-2">
            </div>
          </section>
        </aside>
      </section>

      <section
        class="mt-8 rounded-2xl border border-border/50 bg-card p-6 shadow-sm sm:p-8"
      >
        <h2
          class="text-xl font-bold tracking-tight text-foreground sm:text-2xl"
        >
          Perguntas frequentes sobre agendamento online
        </h2>
        <div
          class="mt-5 divide-y divide-border rounded-xl border border-border"
        >
          {
            faqItems.map((item) => (
              <details class="group px-5 py-4">
                <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-foreground [&::-webkit-details-marker]:hidden">
                  <span class="pr-4">{item.question}</span>
                  <svg
                    class="size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m19 9-7 7-7-7"
                    />
                  </svg>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </section>

      <section class="mt-6 rounded-2xl border border-border/50 bg-card p-5 sm:p-6">
        <h2 class="text-base font-semibold text-foreground">Conteúdos relacionados</h2>
        <nav
          aria-label="Links relacionados"
          class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-muted-foreground"
        >
          <a href="/acuidade-visual" class="transition-colors hover:text-foreground">
            Teste de acuidade visual
          </a>
          <a href="/tela-de-amsler" class="transition-colors hover:text-foreground">
            Tela de Amsler
          </a>
          <a href="/conteudos" class="transition-colors hover:text-foreground">
            Hub de conteúdos
          </a>
        </nav>
      </section>
    </div>
  </main>

  <script
    type="application/json"
    id="cal-online-config"
    set:html={JSON.stringify({ defaultWhatsappNumber })}
  />
  <script>
    interface CityOption {
      slug: string;
      name: string;
      state?: string;
      whatsappNumber?: string;
    }

    interface SlotRange {
      start: string;
      end?: string | null;
    }

    interface SlotsResponse {
      status?: string;
      error?: string;
      data?: {
        slotsByDate?: Record<string, SlotRange[]>;
      };
    }

    interface BookingResponse {
      status?: string;
      error?: string;
      data?: {
        booking?: {
          uid?: string;
          status?: string;
          start?: string;
        };
        cityName?: string;
      };
    }

    interface EventTypesResponse {
      status?: string;
      error?: string;
      data?: Array<{
        citySlug?: string;
        cityName?: string;
        state?: string;
        whatsappNumber?: string;
      }>;
    }

    interface ManualDateChangeDetail {
      value?: string;
    }

    type DateWindowPreset =
      | "current-week"
      | "next-week"
      | "current-month"
      | "current-year"
      | "next-month"
      | "next-3-months"
      | "next-6-months"
      | "next-1-year";

    const MANUAL_DATE_CHANGE_EVENT = "online-booking-manual-date-change";
    const onlineBookingConfig = JSON.parse(
      document.getElementById("cal-online-config")?.textContent ?? "{}",
    ) as { defaultWhatsappNumber?: string };
    const defaultWhatsappNumber =
      onlineBookingConfig.defaultWhatsappNumber?.trim() || "";

    let cityOptionsData: CityOption[] = [];

    const cityOptionsContainer = document.getElementById(
      "city-options",
    ) as HTMLDivElement | null;
    const dateWindowPresetInputs = Array.from(
      document.querySelectorAll<HTMLInputElement>(
        'input[name="dateWindowPreset"]',
      ),
    );
    const form = document.getElementById(
      "online-booking-form",
    ) as HTMLFormElement | null;
    const slotsHelp = document.getElementById(
      "slots-help",
    ) as HTMLParagraphElement | null;
    const manualDateInput = document.getElementById(
      "manual-date-input",
    ) as HTMLInputElement | null;
    const slotsDateList = document.getElementById(
      "slots-date-list",
    ) as HTMLDivElement | null;
    const slotsTimeList = document.getElementById(
      "slots-time-list",
    ) as HTMLDivElement | null;
    const slotsCard = document.getElementById(
      "slots-card",
    ) as HTMLDivElement | null;
    const nameInput = document.getElementById(
      "name",
    ) as HTMLInputElement | null;
    const emailInput = document.getElementById(
      "email",
    ) as HTMLInputElement | null;
    const phoneInput = document.getElementById(
      "phoneNumber",
    ) as HTMLInputElement | null;
    const selectedStartInput = document.getElementById(
      "selectedStart",
    ) as HTMLInputElement | null;
    const timeZoneInput = document.getElementById(
      "timeZone",
    ) as HTMLInputElement | null;
    const statusEl = document.getElementById(
      "form-status",
    ) as HTMLParagraphElement | null;
    const submitButton = document.getElementById(
      "submit-button",
    ) as HTMLButtonElement | null;
    const whatsappFallbackLinks = document.getElementById(
      "whatsapp-fallback-links",
    ) as HTMLDivElement | null;

    if (
      dateWindowPresetInputs.length === 0 ||
      !cityOptionsContainer ||
      !form ||
      !slotsHelp ||
      !manualDateInput ||
      !slotsDateList ||
      !slotsTimeList ||
      !slotsCard ||
      !nameInput ||
      !emailInput ||
      !phoneInput ||
      !selectedStartInput ||
      !timeZoneInput ||
      !statusEl ||
      !submitButton ||
      !whatsappFallbackLinks
    ) {
      throw new Error(
        "Elementos da página de agendamento não foram encontrados.",
      );
    }

    const cityOptionsContainerEl = cityOptionsContainer;
    const dateWindowPresetInputsEl = dateWindowPresetInputs;
    function getSelectedCitySlug() {
      const selected = cityOptionsContainerEl.querySelector<HTMLInputElement>(
        'input[name="citySlug"]:checked',
      );
      return selected?.value ?? "";
    }
    function getSelectedDateWindowPreset(): DateWindowPreset {
      const selected = dateWindowPresetInputsEl.find((radio) => radio.checked);
      return (
        (selected?.value as DateWindowPreset | undefined) ?? "current-week"
      );
    }

    const formEl = form;
    const slotsHelpEl = slotsHelp;
    const manualDateInputEl = manualDateInput;
    const slotsDateListEl = slotsDateList;
    const slotsTimeListEl = slotsTimeList;
    const slotsCardEl = slotsCard;
    const nameInputEl = nameInput;
    const emailInputEl = emailInput;
    const phoneInputEl = phoneInput;
    const selectedStartInputEl = selectedStartInput;
    const timeZoneInputEl = timeZoneInput;
    const statusElText = statusEl;
    const submitButtonEl = submitButton;
    const whatsappFallbackLinksEl = whatsappFallbackLinks;

    const browserTimeZone =
      Intl.DateTimeFormat().resolvedOptions().timeZone || "America/Fortaleza";
    timeZoneInputEl.value = browserTimeZone;
    let currentSlotsByDate: Record<string, SlotRange[]> = {};
    let selectedDate = "";
    let selectedDateWindowPreset: DateWindowPreset =
      getSelectedDateWindowPreset();
    let latestSlotsRequestToken = 0;
    let slotsLoadDebounceId: number | null = null;
    let ongoingSlotsRequests = 0;
    const INPUT_LOAD_DEBOUNCE_MS = 450;
    function normalizeBrazilPhoneDigits(value: string) {
      let digits = value.replace(/\D/g, "");
      if (!digits) return "";
      if (digits.startsWith("00")) {
        digits = digits.slice(2);
      }
      if (digits.startsWith("55") && digits.length > 11) {
        digits = digits.slice(2);
      }
      if (digits.length > 11) {
        digits = digits.slice(-11);
      }
      return digits.slice(0, 11);
    }

    function formatBrazilPhone(digits: string) {
      if (!digits) return "";
      if (digits.length <= 2) return `(${digits}`;
      if (digits.length <= 6) return `(${digits.slice(0, 2)}) ${digits.slice(2)}`;
      if (digits.length <= 10) {
        return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
      }
      return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
    }

    function normalizeAndFormatPhoneInput() {
      const digits = normalizeBrazilPhoneDigits(phoneInputEl.value);
      phoneInputEl.value = formatBrazilPhone(digits);
      return digits;
    }

    function hasValidPhoneInput() {
      const digitsLength = normalizeBrazilPhoneDigits(phoneInputEl.value).length;
      return digitsLength === 10 || digitsLength === 11;
    }


    function cityBySlug(slug: string) {
      return cityOptionsData.find((city) => city.slug === slug) ?? null;
    }

    function escapeHtml(value: string) {
      return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function renderCityOptions() {
      if (!cityOptionsData.length) {
        cityOptionsContainerEl.innerHTML =
          '<span class="text-sm text-muted-foreground">Nenhum local disponível no momento.</span>';
        return;
      }

      cityOptionsContainerEl.innerHTML = cityOptionsData
        .map((city) => {
          const citySlug = escapeHtml(city.slug);
          const cityName = escapeHtml(city.name);
          return `<label class="cursor-pointer">
            <input
              type="radio"
              name="citySlug"
              value="${citySlug}"
              class="peer sr-only"
              required
            />
            <span class="flex h-10 items-center justify-center rounded-md border border-border/60 bg-background px-3 text-sm font-medium text-foreground shadow-xs transition-all hover:border-border hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand">
              ${cityName}
            </span>
          </label>`;
        })
        .join("");
    }

    function renderCityOptionsSkeleton() {
      cityOptionsContainerEl.innerHTML = Array.from({ length: 6 })
        .map(
          () =>
            '<div class="h-10 rounded-md border border-border/50 bg-secondary/50 animate-pulse" aria-hidden="true"></div>',
        )
        .join("");
    }

    async function loadCityOptions() {
      renderCityOptionsSkeleton();
      try {
        const response = await fetch("/api/cal/event-types");
        const payload = (await response.json()) as EventTypesResponse;

        if (!response.ok || payload.status !== "success") {
          throw new Error(
            payload.error || "Não foi possível carregar os locais disponíveis.",
          );
        }

        cityOptionsData = (payload.data ?? [])
          .map((item) => ({
            slug: String(item.citySlug ?? "").trim(),
            name: String(item.cityName ?? "").trim(),
            state: String(item.state ?? "").trim(),
            whatsappNumber: String(item.whatsappNumber ?? "").trim(),
          }))
          .filter((item) => item.slug.length > 0 && item.name.length > 0);

        renderCityOptions();
      } catch (error) {
        cityOptionsData = [];
        cityOptionsContainerEl.innerHTML =
          '<span class="text-sm text-destructive">Erro ao carregar locais da agenda. Atualize a página para tentar novamente.</span>';
        statusElText.textContent =
          error instanceof Error
            ? error.message
            : "Erro ao carregar locais da agenda.";
      }
    }

    function buildWhatsAppLink(city: CityOption) {
      const whatsappNumber = city.whatsappNumber || defaultWhatsappNumber;
      if (!whatsappNumber) return "#";
      const text = encodeURIComponent(
        `Olá, Dr. Leonardo! Gostaria de agendar uma consulta oftalmológica em ${city.name}.`,
      );
      return `https://api.whatsapp.com/send?phone=${whatsappNumber}&text=${text}`;
    }

    function clearSlotsAndSelection() {
      selectedDate = "";
      selectedStartInputEl.value = "";
      slotsDateListEl.innerHTML = "";
      slotsTimeListEl.innerHTML = "";
      updateSummary();
    }

    function hasRequiredInputsFilled() {
      return (
        nameInputEl.value.trim().length > 0 &&
        emailInputEl.value.trim().length > 0 &&
        hasValidPhoneInput()
      );
    }

    function isReadyToLoadSlots() {
      return Boolean(getSelectedCitySlug()) && hasRequiredInputsFilled();
    }

    function clearDateWindowPresetSelection() {
      dateWindowPresetInputsEl.forEach((radio) => {
        radio.checked = false;
      });
    }

    function shouldLoadInitialSlotsFromInputs() {
      return (
        isReadyToLoadSlots() &&
        !selectedStartInputEl.value &&
        !getAvailableDateKeys().length
      );
    }

    function clearScheduledInputSlotsLoad() {
      if (slotsLoadDebounceId !== null) {
        window.clearTimeout(slotsLoadDebounceId);
        slotsLoadDebounceId = null;
      }
    }

    function scheduleInputDrivenSlotsLoad() {
      clearScheduledInputSlotsLoad();
      if (!shouldLoadInitialSlotsFromInputs()) return;

      slotsLoadDebounceId = window.setTimeout(() => {
        slotsLoadDebounceId = null;
        if (!shouldLoadInitialSlotsFromInputs()) return;
        if (ongoingSlotsRequests > 0) return;
        loadSlots();
      }, INPUT_LOAD_DEBOUNCE_MS);
    }

    function renderBlockedSlotsState() {
      const citySlug = getSelectedCitySlug();
      slotsCardEl.classList.add("hidden");
      renderWhatsAppFallback(citySlug);
      if (!citySlug) {
        slotsHelpEl.textContent =
          "Selecione um local para carregar os horários.";
      } else {
        slotsHelpEl.textContent =
          "Preencha nome, e-mail e um telefone válido para carregar datas e horários.";
      }
      clearSlotsAndSelection();
    }

    function renderWhatsAppFallback(selectedSlug: string) {
      const cityList = selectedSlug
        ? cityOptionsData.filter((city) => city.slug === selectedSlug)
        : cityOptionsData;

      if (!cityList.length) {
        whatsappFallbackLinksEl.innerHTML =
          '<span class="text-xs text-muted-foreground">Sem locais disponíveis no momento.</span>';
        return;
      }

      whatsappFallbackLinksEl.innerHTML = cityList
        .map((city) => {
          const cityLabel = `${city.name}${city.state ? ` (${city.state})` : ""}`;
          return `<a href="${buildWhatsAppLink(city)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-md border border-border bg-background px-3 py-2 text-xs font-medium text-foreground shadow-xs transition-colors hover:bg-accent">${escapeHtml(cityLabel)}</a>`;
        })
        .join("");
    }

    function normalizeSlotsByDate(slotsByDate?: Record<string, SlotRange[]>) {
      const normalized: Record<string, SlotRange[]> = {};

      Object.entries(slotsByDate ?? {}).forEach(([dateKey, daySlots]) => {
        const cleaned = (daySlots ?? [])
          .filter((slot) => Boolean(slot?.start))
          .map((slot) => ({
            start: slot.start,
            end: slot.end ?? null,
          }))
          .sort((a, b) => a.start.localeCompare(b.start));

        if (cleaned.length > 0) {
          normalized[dateKey] = cleaned;
        }
      });

      return normalized;
    }

    function formatTime(isoDate: string) {
      const date = new Date(isoDate);
      return new Intl.DateTimeFormat("pt-BR", {
        hour: "2-digit",
        minute: "2-digit",
      }).format(date);
    }

    function formatDateLabel(dateKey: string) {
      const date = new Date(`${dateKey}T12:00:00`);
      return new Intl.DateTimeFormat("pt-BR", {
        weekday: "short",
        day: "2-digit",
        month: "2-digit",
      }).format(date);
    }

    function formatDateLong(dateKey: string) {
      const date = new Date(`${dateKey}T12:00:00`);
      return new Intl.DateTimeFormat("pt-BR", {
        weekday: "long",
        day: "2-digit",
        month: "long",
      }).format(date);
    }

    function toIsoDateLocal(date: Date) {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }

    function atMidday(date: Date) {
      return new Date(
        date.getFullYear(),
        date.getMonth(),
        date.getDate(),
        12,
        0,
        0,
        0,
      );
    }

    function addDays(date: Date, days: number) {
      const next = atMidday(date);
      next.setDate(next.getDate() + days);
      return next;
    }

    function milestoneWindow(
      today: Date,
      targetDays: number,
      toleranceBeforeDays = 7,
    ) {
      const start = addDays(
        today,
        Math.max(0, targetDays - toleranceBeforeDays),
      );
      const end = addDays(today, targetDays);
      return { start: toIsoDateLocal(start), end: toIsoDateLocal(end) };
    }

    function startOfWeek(date: Date) {
      const next = atMidday(date);
      const day = (next.getDay() + 6) % 7;
      next.setDate(next.getDate() - day);
      return next;
    }

    function startOfMonth(date: Date) {
      return new Date(date.getFullYear(), date.getMonth(), 1, 12, 0, 0, 0);
    }

    function endOfMonth(date: Date) {
      return new Date(date.getFullYear(), date.getMonth() + 1, 0, 12, 0, 0, 0);
    }

    function startOfYear(date: Date) {
      return new Date(date.getFullYear(), 0, 1, 12, 0, 0, 0);
    }

    function endOfYear(date: Date) {
      return new Date(date.getFullYear(), 11, 31, 12, 0, 0, 0);
    }

    function isIsoDate(value: string) {
      return /^\d{4}-\d{2}-\d{2}$/.test(value);
    }

    function getWindowSelection(preset: DateWindowPreset) {
      const today = atMidday(new Date());

      switch (preset) {
        case "current-week": {
          const start = startOfWeek(today);
          return {
            start: toIsoDateLocal(start),
            end: toIsoDateLocal(addDays(start, 6)),
            label: "semana atual",
          };
        }
        case "next-week": {
          const start = addDays(startOfWeek(today), 7);
          return {
            start: toIsoDateLocal(start),
            end: toIsoDateLocal(addDays(start, 6)),
            label: "próxima semana",
          };
        }
        case "current-month": {
          return {
            start: toIsoDateLocal(startOfMonth(today)),
            end: toIsoDateLocal(endOfMonth(today)),
            label: "mês atual",
          };
        }
        case "current-year": {
          return {
            start: toIsoDateLocal(startOfYear(today)),
            end: toIsoDateLocal(endOfYear(today)),
            label: "esse ano",
          };
        }
        case "next-month": {
          const nextMonth = new Date(
            today.getFullYear(),
            today.getMonth() + 1,
            1,
            12,
            0,
            0,
            0,
          );
          return {
            start: toIsoDateLocal(startOfMonth(nextMonth)),
            end: toIsoDateLocal(endOfMonth(nextMonth)),
            label: "próximo mês",
          };
        }
        case "next-3-months": {
          const window = milestoneWindow(today, 90);
          return {
            ...window,
            label: "em 3 meses (com tolerância de 1 semana antes)",
          };
        }
        case "next-6-months": {
          const window = milestoneWindow(today, 180);
          return {
            ...window,
            label: "em 6 meses (com tolerância de 1 semana antes)",
          };
        }
        case "next-1-year": {
          const window = milestoneWindow(today, 365);
          return {
            ...window,
            label: "em 1 ano (com tolerância de 1 semana antes)",
          };
        }
      }
    }

    function updateSummary() {
      // Mantido por compatibilidade com o fluxo atual.
    }

    function getAvailableDateKeys() {
      return Object.keys(currentSlotsByDate).sort((a, b) => a.localeCompare(b));
    }

    function renderSlotsSkeleton() {
      slotsDateListEl.innerHTML = Array.from({ length: 6 })
        .map(
          () =>
            `<div class="h-10 rounded-md border border-border/50 bg-secondary/50 animate-pulse" aria-hidden="true"></div>`,
        )
        .join("");

      slotsTimeListEl.innerHTML = Array.from({ length: 6 })
        .map(
          () =>
            `<div class="h-11 rounded-md border border-border/50 bg-secondary/50 animate-pulse" aria-hidden="true"></div>`,
        )
        .join("");
    }

    function setSlotsLoadingState(isLoading: boolean) {
      if (isLoading) {
        slotsDateListEl.setAttribute("aria-busy", "true");
        slotsTimeListEl.setAttribute("aria-busy", "true");
      } else {
        slotsDateListEl.removeAttribute("aria-busy");
        slotsTimeListEl.removeAttribute("aria-busy");
      }
    }

    function renderDateOptions() {
      const dateKeys = getAvailableDateKeys();
      if (!dateKeys.length) {
        selectedDate = "";
        slotsDateListEl.innerHTML = "";
        return;
      }

      if (!dateKeys.includes(selectedDate)) {
        selectedDate = dateKeys[0];
      }

      slotsDateListEl.innerHTML = dateKeys
        .map(
          (dateKey) =>
            `<label class="cursor-pointer">
              <input class="peer sr-only" type="radio" name="slotDate" value="${dateKey}" ${dateKey === selectedDate ? "checked" : ""} />
              <span class="inline-flex h-10 w-full items-center justify-center rounded-md border border-border/70 bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent peer-checked:border-brand/40 peer-checked:bg-brand/10 peer-checked:text-brand">
                ${formatDateLabel(dateKey)}
              </span>
            </label>`,
        )
        .join("");
    }

    function renderTimeOptions() {
      const daySlots = currentSlotsByDate[selectedDate] ?? [];
      selectedStartInputEl.value = daySlots[0]?.start ?? "";

      if (!daySlots.length) {
        slotsTimeListEl.innerHTML = "";
        slotsHelpEl.textContent =
          "Sem horários para o dia selecionado. Tente outro dia.";
        updateSummary();
        return;
      }

      slotsTimeListEl.innerHTML = daySlots
        .slice(0, 24)
        .map(
          (slot, index) =>
            `<label class="group relative flex cursor-pointer items-center gap-3 rounded-md border border-border bg-background px-3 py-2 text-sm transition-colors hover:bg-accent">
              <input class="peer sr-only" type="radio" name="slotStart" value="${slot.start}" ${index === 0 ? "checked" : ""} />
              <span class="inline-flex size-4 shrink-0 items-center justify-center rounded-full border border-border bg-background transition-colors peer-checked:border-brand/40 peer-checked:bg-brand/10">
                <span class="size-2 rounded-full bg-brand opacity-0 transition-opacity peer-checked:opacity-100"></span>
              </span>
              <span class="font-medium text-foreground">${formatTime(slot.start)}</span>
              ${index === 0 ? '<span class="ml-auto rounded-full border border-brand/30 bg-brand/10 px-2 py-0.5 text-[10px] font-semibold text-brand">Mais cedo</span>' : ""}
            </label>`,
        )
        .join("");
      updateSummary();
    }

    function renderSlotsByDate(
      slotsByDate: Record<string, SlotRange[]>,
      preferredDate = "",
    ) {
      currentSlotsByDate = slotsByDate;
      const dateKeys = getAvailableDateKeys();

      if (!dateKeys.length) {
        selectedDate = "";
        selectedStartInputEl.value = "";
        slotsDateListEl.innerHTML = "";
        slotsTimeListEl.innerHTML = "";
        slotsHelpEl.textContent =
          "Sem horários no período consultado. Tente outra janela ou data.";
        updateSummary();
        return;
      }

      if (preferredDate && dateKeys.includes(preferredDate)) {
        selectedDate = preferredDate;
      } else if (!dateKeys.includes(selectedDate)) {
        selectedDate = dateKeys[0];
      }

      slotsHelpEl.textContent = "Escolha o dia e depois o horário.";
      renderDateOptions();
      renderTimeOptions();
      updateSummary();
    }

    async function loadSlots(options?: { manualDate?: string }) {
      const requestToken = ++latestSlotsRequestToken;
      clearScheduledInputSlotsLoad();
      const citySlug = getSelectedCitySlug();
      renderWhatsAppFallback(citySlug);

      if (!citySlug || !hasRequiredInputsFilled()) {
        setSlotsLoadingState(false);
        renderBlockedSlotsState();
        return;
      }

      slotsCardEl.classList.remove("hidden");
      const typedDate = (options?.manualDate ?? manualDateInputEl.value).trim();
      const usingManualDate = isIsoDate(typedDate);
      const selectedWindow = getWindowSelection(selectedDateWindowPreset);
      const start = usingManualDate ? typedDate : selectedWindow.start;
      const end = usingManualDate ? typedDate : selectedWindow.end;
      const periodLabel = usingManualDate
        ? `data ${formatDateLong(typedDate)}`
        : selectedWindow.label;

      setSlotsLoadingState(true);
      slotsHelpEl.textContent = `Carregando horários para ${periodLabel}...`;
      renderSlotsSkeleton();
      statusElText.textContent = "";
      ongoingSlotsRequests += 1;

      const query = new URLSearchParams({
        citySlug,
        timeZone: browserTimeZone,
        start,
        end,
      });

      try {
        const response = await fetch(`/api/cal/slots?${query.toString()}`);
        const payload = (await response.json()) as SlotsResponse;
        if (requestToken !== latestSlotsRequestToken) return;

        if (!response.ok || payload.status !== "success") {
          throw new Error(
            payload.error || "Não foi possível carregar os horários.",
          );
        }

        renderSlotsByDate(
          normalizeSlotsByDate(payload.data?.slotsByDate),
          usingManualDate ? typedDate : "",
        );
      } catch (error) {
        if (requestToken !== latestSlotsRequestToken) return;
        slotsHelpEl.textContent =
          error instanceof Error
            ? error.message
            : "Erro ao carregar datas e horários disponíveis.";
        slotsDateListEl.innerHTML = "";
        slotsTimeListEl.innerHTML = "";
        updateSummary();
      } finally {
        ongoingSlotsRequests = Math.max(0, ongoingSlotsRequests - 1);
        if (requestToken === latestSlotsRequestToken) {
          setSlotsLoadingState(false);
        }
      }
    }

    cityOptionsContainerEl.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || target.name !== "citySlug") {
        return;
      }
      updateSummary();
      if (!isReadyToLoadSlots()) {
        renderBlockedSlotsState();
        return;
      }
      loadSlots();
    });

    dateWindowPresetInputsEl.forEach((radio) => {
      radio.addEventListener("change", () => {
        selectedDateWindowPreset = getSelectedDateWindowPreset();
        manualDateInputEl.value = "";
        selectedStartInputEl.value = "";
        if (!isReadyToLoadSlots()) {
          renderBlockedSlotsState();
          return;
        }
        loadSlots();
      });
    });

    window.addEventListener(MANUAL_DATE_CHANGE_EVENT, (event) => {
      const customEvent = event as CustomEvent<ManualDateChangeDetail>;
      const value = (customEvent.detail?.value ?? "").trim();
      manualDateInputEl.value = value;
      selectedStartInputEl.value = "";

      if (value && isIsoDate(value)) {
        clearDateWindowPresetSelection();
        if (!isReadyToLoadSlots()) {
          renderBlockedSlotsState();
          return;
        }
        loadSlots({ manualDate: value });
        return;
      }

      selectedDateWindowPreset = getSelectedDateWindowPreset();
      if (!isReadyToLoadSlots()) {
        renderBlockedSlotsState();
        return;
      }
      loadSlots();
    });

    slotsDateListEl.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.name !== "slotDate") return;
      selectedDate = target.value;
      renderTimeOptions();
      updateSummary();
    });

    slotsTimeListEl.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.name !== "slotStart") return;
      selectedStartInputEl.value = target.value;
      updateSummary();
    });

    phoneInputEl.addEventListener("input", () => {
      normalizeAndFormatPhoneInput();
      if (!isReadyToLoadSlots()) {
        renderBlockedSlotsState();
      } else {
        scheduleInputDrivenSlotsLoad();
      }
    });

    phoneInputEl.addEventListener("change", () => {
      normalizeAndFormatPhoneInput();
      if (!isReadyToLoadSlots()) {
        renderBlockedSlotsState();
      } else {
        scheduleInputDrivenSlotsLoad();
      }
    });

    phoneInputEl.addEventListener("blur", () => {
      normalizeAndFormatPhoneInput();
    });

    nameInputEl.addEventListener("input", () => {
      if (!isReadyToLoadSlots()) {
        renderBlockedSlotsState();
      } else {
        scheduleInputDrivenSlotsLoad();
      }
    });

    emailInputEl.addEventListener("input", () => {
      if (!isReadyToLoadSlots()) {
        renderBlockedSlotsState();
      } else {
        scheduleInputDrivenSlotsLoad();
      }
    });

    formEl.addEventListener("submit", async (event) => {
      event.preventDefault();
      statusElText.textContent = "";
      normalizeAndFormatPhoneInput();

      const formData = new FormData(formEl);
      const citySlug = String(formData.get("citySlug") || "");
      const start =
        selectedStartInputEl.value || String(formData.get("slotStart") || "");
      const name = String(formData.get("name") || "");
      const email = String(formData.get("email") || "");
      const phoneNumber = String(formData.get("phoneNumber") || "");
      const timeZone = String(formData.get("timeZone") || browserTimeZone);

      if (!citySlug || !start) {
        statusElText.textContent =
          "Selecione local e horário antes de continuar.";
        return;
      }
      if (!hasValidPhoneInput()) {
        statusElText.textContent =
          "Informe um telefone válido com DDD para continuar.";
        return;
      }

      submitButtonEl.disabled = true;
      submitButtonEl.textContent = "Processando...";

      try {
        const response = await fetch("/api/cal/bookings", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            citySlug,
            start,
            name,
            email,
            phoneNumber,
            timeZone,
          }),
        });

        const payload = (await response.json()) as BookingResponse;
        if (!response.ok || payload.status !== "success") {
          throw new Error(
            payload.error || "Não foi possível concluir o agendamento.",
          );
        }

        const city = cityBySlug(citySlug);
        const bookingUid = payload.data?.booking?.uid;
        const cityName = payload.data?.cityName || city?.name || "";
        const bookingStart = payload.data?.booking?.start || start;
        const bookingStatus = payload.data?.booking?.status || "pending";
        const redirectQuery = new URLSearchParams({
          uid: bookingUid || "",
          city: cityName,
          start: bookingStart,
          status: bookingStatus,
        });
        const analyticsWindow = window as Window & {
          gtag?: (...args: unknown[]) => void;
          dataLayer?: Array<Record<string, unknown>>;
        };
        if (typeof analyticsWindow.gtag === "function") {
          analyticsWindow.gtag("event", "submit_booking", {
            city: cityName,
            channel: "online",
            status: bookingStatus,
          });
        }
        if (analyticsWindow.dataLayer) {
          analyticsWindow.dataLayer.push({
            event: "submit_booking",
            city: cityName,
            channel: "online",
            status: bookingStatus,
          });
        }
        window.location.href = `/agendamento-pendente?${redirectQuery.toString()}`;
        return;
      } catch (error) {
        statusElText.textContent =
          error instanceof Error
            ? error.message
            : "Erro ao concluir agendamento online.";
      } finally {
        submitButtonEl.disabled = false;
        submitButtonEl.textContent = "Agendar consulta";
      }
    });

    async function initBookingPage() {
      await loadCityOptions();
      normalizeAndFormatPhoneInput();
      renderBlockedSlotsState();
      updateSummary();
    }

    void initBookingPage();
  </script>

  <Footer />
  <WhatsAppFloat client:idle />
</Layout>
