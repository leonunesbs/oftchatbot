---
export const prerender = false;

/** Encaminha para a home com o parâmetro que abre o diálogo de agendamento (sem embed). */
const url = Astro.url;
const dest = new URL("/", url.origin);
dest.searchParams.set("agendar", "1");
url.searchParams.forEach((value, key) => {
  if (key === "agendar") return;
  dest.searchParams.set(key, value);
});
return Astro.redirect(dest.toString(), 307);
---
