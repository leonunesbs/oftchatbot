---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { clusterTopics } from "@/config/semantic-clusters";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

const title = "Conteúdos de Oftalmologia | Retina, Catarata e Triagem Visual";
const description =
  "Hub de conteúdos de oftalmologia com guias de triagem visual, retina e agendamento de consulta.";
const canonical = new URL("/conteudos", siteConfig.canonical).href;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: siteConfig.canonical },
    { "@type": "ListItem", position: 2, name: "Conteúdos", item: canonical },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Conteúdos de Oftalmologia",
  itemListElement: clusterTopics.map((topic, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: topic.title,
    url: new URL(topic.href, siteConfig.canonical).href,
  })),
};

const conditionSchemas = clusterTopics
  .filter((topic) => Boolean(topic.condition))
  .map((topic) => ({
    "@context": "https://schema.org",
    "@type": "MedicalCondition",
    name: topic.condition,
    possibleTreatment: topic.procedure
      ? {
          "@type": "MedicalTherapy",
          name: topic.procedure,
        }
      : undefined,
  }));

const allSchemas = [breadcrumbSchema, itemListSchema, ...conditionSchemas];
---

<Layout title={title} description={description} ogType="article">
  {
    allSchemas.map((schema) => (
      <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }

  <Header />
  <main id="conteudo-principal" tabindex="-1" class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li><a href="/" class="transition-colors hover:text-foreground">Início</a></li>
        <li aria-hidden="true" class="select-none">/</li>
        <li><span class="font-medium text-foreground" aria-current="page">Conteúdos</span></li>
      </ol>
    </nav>

    <section class="rounded-2xl border border-border/60 bg-card p-6 sm:p-8">
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Hub de Conteúdos em Oftalmologia</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
        Explore conteúdos de triagem visual, retina e agendamento. Esta página organiza temas por
        intenção para facilitar navegação, reforçar autoridade médica e conectar o conteúdo à
        jornada de consulta.
      </p>
    </section>

    <section class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        clusterTopics.map((topic) => (
          <article class="rounded-xl border border-border/60 bg-card p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand">
              {topic.intent === "transactional" ? "Transacional" : "Informacional"}
            </p>
            <h2 class="mt-2 text-lg font-semibold text-foreground">{topic.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{topic.description}</p>
            <a href={topic.href} class="mt-4 inline-flex text-sm font-medium text-brand hover:underline">
              Abrir conteúdo
            </a>
          </article>
        ))
      }
    </section>
  </main>
  <Footer />
</Layout>

