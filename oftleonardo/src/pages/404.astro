---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";

const title = "Página não encontrada | Leonardo Nunes · Oftalmologista";
const description =
  "A página que você procurou não foi encontrada. Volte para o início e acesse os conteúdos de oftalmologia de Leonardo Nunes.";
---

<Layout title={title} description={description}>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <Header />

  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative isolate overflow-x-clip"
  >
    <section
      class="mx-auto flex min-h-[calc(100dvh-11rem)] max-w-4xl items-center justify-center px-4 py-16"
    >
      <div class="w-full rounded-2xl border border-border/50 bg-card px-6 py-10 text-center shadow-sm sm:px-10 sm:py-12">
        <p
          class="inline-flex rounded-md border border-brand/30 bg-brand/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-brand"
        >
          Erro 404
        </p>

        <h1 class="mt-5 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Página não encontrada
        </h1>

        <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
          O link pode estar desatualizado, incorreto ou a página pode ter sido movida.
          Use as opções abaixo para continuar sua navegação.
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/"
            class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/90"
          >
            Voltar para o início
          </a>
          <a
            href="/acuidade-visual"
            class="inline-flex h-10 items-center justify-center rounded-md border border-border bg-background px-6 text-sm font-medium text-foreground transition-all hover:bg-accent hover:text-accent-foreground"
          >
            Fazer teste de acuidade visual
          </a>
        </div>

        <nav
          aria-label="Sugestões de navegação"
          class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm text-muted-foreground"
        >
          <a href="/#atuacao" class="transition-colors hover:text-foreground">
            Especialidades
          </a>
          <a href="/#atendimento" class="transition-colors hover:text-foreground">
            Cidades de atendimento
          </a>
          <a href="/#faq" class="transition-colors hover:text-foreground">
            Perguntas frequentes
          </a>
        </nav>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
