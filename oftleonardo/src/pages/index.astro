---
export const prerender = true;

import Cities from "@/components/Cities.astro";
import CTAFinal from "@/components/CTAFinal.astro";
import Differentials from "@/components/Differentials.astro";
import ExperienceStats from "@/components/ExperienceStats.astro";
import FAQ from "@/components/FAQ.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import HomeContentSection from "@/components/HomeContentSection.astro";
import HomeCosmicBackdrop from "@/components/HomeCosmicBackdrop.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import Services from "@/components/Services.astro";
import VisualAcuityFloat from "@/components/VisualAcuityFloat";
import WhatsAppFloat from "@/components/WhatsAppFloat";
import { siteConfig } from "@/config/site";
import { buildHomeSeoFromCity, getDefaultGeoCity } from "@/lib/geo";
import type { GeoCityResolution } from "@/lib/geo/resolve-city";
import { loadHomeConteudos } from "@/lib/home-featured-content";
import Layout from "@/layouts/Layout.astro";

const geoCity: GeoCityResolution =
  Astro.locals.geoCity ??
  (() => {
    const c = getDefaultGeoCity();
    return {
      slug: c.slug,
      name: c.name,
      state: c.state,
      source: "fallback",
    };
  })();

const dynamicSeo = buildHomeSeoFromCity(geoCity.name);

const { featuredContent, presbiopiaArticle, premiumLensesArticle } =
  await loadHomeConteudos();

const spotlightForSchema = [
  ...(presbiopiaArticle ? [presbiopiaArticle] : []),
  ...(premiumLensesArticle ? [premiumLensesArticle] : []),
];
const spotlightIds = new Set(spotlightForSchema.map((a) => a.id));
const guidesForStructuredData = [
  ...spotlightForSchema,
  ...featuredContent.filter((a) => !spotlightIds.has(a.id)),
];

const contentItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Guias em oftalmologia em destaque",
  description:
    "Seleção de conteúdos educativos sobre saúde ocular com orientação clínica revisada por especialista.",
  itemListElement: guidesForStructuredData.map((a, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: a.data.title,
    url: new URL(`/conteudos/${a.id}`, siteConfig.canonical).href,
  })),
};
---

<Layout
  includeFAQSchema={true}
  title={dynamicSeo.title}
  description={dynamicSeo.description}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(contentItemListSchema)}
  />
  <Header />
  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative isolate overflow-x-clip"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(40%_30%_at_0%_35%,color-mix(in_oklch,var(--color-brand)_4%,transparent),transparent),radial-gradient(35%_25%_at_100%_68%,color-mix(in_oklch,var(--color-brand)_3%,transparent),transparent)]"
      aria-hidden="true"
    >
    </div>
    <Hero />
    <div class="home-cosmic-anchor relative isolate overflow-x-clip">
      <div
        class="pointer-events-none absolute inset-0 -z-10 overflow-visible"
        aria-hidden="true"
      >
        <HomeCosmicBackdrop />
      </div>
      <div class="home-post-hero-stack">
        <div class="scroll-section">
          <Services />
        </div>
        <div class="scroll-section">
          <ExperienceStats />
        </div>
        <div class="scroll-section">
          <Differentials />
        </div>
        <div class="scroll-section">
          <HomeContentSection
            cityName={geoCity.name}
            items={featuredContent}
            presbiopiaSpotlight={presbiopiaArticle}
            premiumLensesSpotlight={premiumLensesArticle}
          />
        </div>
        <div class="scroll-section">
          <Cities />
        </div>
        <div class="scroll-section">
          <HowItWorks />
        </div>
        <div class="scroll-section">
          <FAQ />
        </div>
        <div class="scroll-section">
          <CTAFinal />
        </div>
      </div>
    </div>
    <script>
      import { initHomeCosmicAnchor } from "@/lib/home-cosmic-anchor";
      import { initHomeScrollReveal } from "@/lib/home-scroll-reveal";
      initHomeCosmicAnchor();
      initHomeScrollReveal();
    </script>
  </main>
  <Footer />
  <VisualAcuityFloat client:idle />
  <WhatsAppFloat client:idle />
</Layout>
