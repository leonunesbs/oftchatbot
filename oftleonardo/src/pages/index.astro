---
export const prerender = false;

import Cities from "@/components/Cities.astro";
import CTAFinal from "@/components/CTAFinal.astro";
import Differentials from "@/components/Differentials.astro";
import ExperienceStats from "@/components/ExperienceStats.astro";
import FAQ from "@/components/FAQ.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import HomeContentSection from "@/components/HomeContentSection.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import ParallaxArtifacts from "@/components/ParallaxArtifacts";
import Services from "@/components/Services.astro";
import VisualAcuityFloat from "@/components/VisualAcuityFloat";
import WhatsAppFloat from "@/components/WhatsAppFloat";
import { siteConfig } from "@/config/site";
import { buildHomeSeoFromCity, resolveGeoCity } from "@/lib/geo";
import { pickFeaturedArticles } from "@/lib/home-featured-content";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const geoCity =
  Astro.locals.geoCity ??
  (await resolveGeoCity({
    request: Astro.request,
    cookies: Astro.cookies,
  }));

const dynamicSeo = buildHomeSeoFromCity(geoCity.name);

const articles = await getCollection("conteudos");
const featuredContent = pickFeaturedArticles(articles);
const presbiopiaArticle = articles.find((a) => a.id === "presbiopia") ?? null;
const guidesForStructuredData = presbiopiaArticle
  ? [presbiopiaArticle, ...featuredContent.filter((a) => a.id !== "presbiopia")]
  : featuredContent;

const contentItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Guias em oftalmologia em destaque",
  description:
    "Seleção de conteúdos educativos sobre saúde ocular com orientação clínica revisada por especialista.",
  itemListElement: guidesForStructuredData.map((a, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: a.data.title,
    url: new URL(`/conteudos/${a.id}`, siteConfig.canonical).href,
  })),
};
---

<Layout
  includeFAQSchema={true}
  title={dynamicSeo.title}
  description={dynamicSeo.description}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(contentItemListSchema)}
  />
  <Header />
  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative isolate overflow-x-clip"
  >
    <ParallaxArtifacts />
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(40%_30%_at_0%_35%,color-mix(in_oklch,var(--color-brand)_6%,transparent),transparent),radial-gradient(35%_25%_at_100%_68%,color-mix(in_oklch,var(--color-brand)_5%,transparent),transparent)]"
      aria-hidden="true"
    >
    </div>
    <Hero />
    <div class="defer-render scroll-section">
      <Services />
    </div>
    <div class="defer-render scroll-section">
      <ExperienceStats />
    </div>
    <div class="defer-render scroll-section">
      <Differentials />
    </div>
    <div class="defer-render scroll-section">
      <HomeContentSection
        cityName={geoCity.name}
        items={featuredContent}
        presbiopiaSpotlight={presbiopiaArticle}
      />
    </div>
    <div class="defer-render scroll-section">
      <Cities />
    </div>
    <div class="defer-render scroll-section">
      <HowItWorks />
    </div>
    <div class="defer-render scroll-section">
      <FAQ />
    </div>
    <div class="defer-render scroll-section">
      <CTAFinal />
    </div>
  </main>
  <Footer />
  <VisualAcuityFloat client:idle />
  <WhatsAppFloat client:idle />
</Layout>
