---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import OsdiCalculator from "@/components/osdi/OsdiCalculator";
import ScheduleConsultationSection from "@/components/ScheduleConsultationSection.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

const title =
  "Calculadora de olho seco online | Questionário OSDI gratuito | Leonardo Nunes";
const description =
  "Calcule o impacto dos sintomas de olho seco na última semana: irritação, telas, ambientes secos e mais. Ferramenta baseada no questionário OSDI (Ocular Surface Disease Index). Triagem educativa — não substitui consulta. Agende com oftalmologista em Fortaleza.";
const keywords =
  "calculadora olho seco, teste olho seco online, síndrome do olho seco, ressecamento olho, olho seco sintomas, questionário olho seco, lacrimejamento excessivo, irritação ocular, olho seco computador, blefarite, dor ocular, fotofobia, OSDI, índice superfície ocular, oftalmologista Fortaleza";

const canonical = new URL("/calculadora-olho-seco", siteConfig.canonical).href;

const howToSteps = [
  {
    name: "Leia o período de referência",
    text: "A calculadora avalia a última semana com base no questionário clínico OSDI. Uma pergunta aparece por vez: escolha a opção que melhor descreve a frequência do sintoma ou o quanto seus olhos limitaram a atividade.",
  },
  {
    name: "Avance pelos 12 itens",
    text: "Os cinco primeiros itens tratam de sintomas. Os itens 6 a 9 avaliam limitações em tarefas como leitura e tela. Os itens 10 a 12 avaliam desconforto em ambientes específicos. Ao tocar em uma resposta, você segue para a próxima pergunta.",
  },
  {
    name: "Use “não se aplica” quando fizer sentido",
    text: "Nos itens 6 a 12, escolha essa opção se você não realizou a atividade ou não esteve na situação na última semana. Essas questões não entram no denominador do cálculo.",
  },
  {
    name: "Veja o resultado em escala 0–100",
    text: "O resultado segue a fórmula do OSDI: (soma dos pontos) × 25 ÷ (número de questões válidas). Valores mais altos indicam maior impacto. A interpretação em faixas (normal, leve, moderado, severo) segue a literatura clínica do índice.",
  },
];

const faqItems = [
  {
    question: "O que é esta calculadora de olho seco?",
    answer:
      "É uma versão digital do questionário OSDI (Ocular Surface Disease Index), validado na medicina para medir sintomas e o impacto funcional da doença da superfície ocular — em especial o olho seco — na última semana. Ele ajuda a quantificar queixas como sensibilidade à luz, sensação de areia, dor ou irritação, visão que oscila e limitação em leitura ou uso de telas, produzindo uma pontuação de 0 a 100.",
  },
  {
    question: "Esta calculadora substitui consulta com oftalmologista?",
    answer:
      "Não. O resultado é educativo e orientativo. O diagnóstico de olho seco e de causas associadas (por exemplo, blefarite, disfunção das glândulas da pálpebra, uso de lentes ou medicamentos) exige exame clínico, e às vezes testes complementares. Use o resultado como ponto de partida para conversar com o Dr Leonardo ou outro especialista.",
  },
  {
    question: "Como interpretar a pontuação (escala OSDI)?",
    answer:
      "Na prática clínica, valores muito baixos costumam ser compatíveis com impacto pequeno no índice; faixas mais altas sugerem maior sintoma ou limitação. Os cortes usados na literatura para classificar normal, leve, moderado e severo orientam a gravidade aproximada, mas a conduta individual depende do exame físico e do contexto de cada pessoa.",
  },
  {
    question: "Por que lacrimejamento pode aparecer em quem tem olho seco?",
    answer:
      "O olho seco nem sempre significa 'pouca lágrima' de forma simples. Muitas vezes há instabilidade do filme lacrimal ou irritação da superfície, e o organismo pode responder com lacrimejamento reflexo — uma resposta que pode coexistir com queimação, sensação de corpo estranho ou visão embaçada que piora ao longo do dia.",
  },
  {
    question: "Apneia do sono e distúrbios do sono têm relação com olho seco?",
    answer:
      "Há evidências de associação entre sono de má qualidade, apneia obstrutiva do sono e sintomas oculares à superfície, possivelmente por mecanismos inflamatórios, padrão respiratório à noite e hábitos diurnos (por exemplo, maior tempo em ambientes secos ou frente a telas). Isso não significa que uma coisa cause a outra em todo caso, mas vale relatar sono fragmentado, ronco intenso ou sonolência diurna na consulta.",
  },
  {
    question: "Estresse e ansiedade influenciam os sintomas?",
    answer:
      "Fatores emocionais e de estresse podem modular a percepção de desconforto ocular e o hábito de piscar (especialmente em frente ao computador), o que piora a estabilidade do filme lacrimal. O cuidado oftalmológico continua essencial para afastar outras causas e orientar tratamento da superfície ocular e das pálpebras.",
  },
  {
    question: "O que é blefarite e como se relaciona com olho seco?",
    answer:
      "Blefarite é inflamação das margens das pálpebras; pode coexistir com disfunção das glândulas de Meibômio, alterando o óleo da lágrima e favorecendo evaporização e irritação. Os sintomas podem sobrepor-se aos do olho seco. A avaliação médica define se há blefarite, rosácea ocular ou outras condições e qual tratamento é adequado.",
  },
  {
    question: "Dor ocular ou dor de cabeça sempre indicam olho seco?",
    answer:
      "Não. Dor ao redor dos olhos ou sensação de peso pode ter várias causas (incluindo problemas de superfície, mas também causas neurológicas ou de sinusite, entre outras). Se a dor for intensa, súbita, com perda de visão ou trauma, busque atendimento urgente conforme orientação local. Para sintomas persistentes leves a moderados, a consulta oftalmológica de rotina ajuda a esclarecer.",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Início",
      item: siteConfig.canonical,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Calculadora de olho seco",
      item: canonical,
    },
  ],
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Calculadora de olho seco (questionário OSDI)",
  description:
    "Calculadora online gratuita para sintomas de olho seco, baseada no questionário OSDI (Ocular Surface Disease Index), com resultado em escala 0–100.",
  url: canonical,
  applicationCategory: "HealthApplication",
  operatingSystem: "All",
  browserRequirements: "Requires JavaScript. Requires a modern web browser.",
  inLanguage: "pt-BR",
  isAccessibleForFree: true,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "BRL",
  },
  author: {
    "@type": "Physician",
    name: siteConfig.name,
    url: siteConfig.canonical,
    medicalSpecialty: "Ophthalmology",
  },
  provider: {
    "@type": "MedicalBusiness",
    name: `${siteConfig.name} · ${siteConfig.title}`,
    url: siteConfig.canonical,
  },
};

const medicalPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: "Calculadora de olho seco online",
  description,
  url: canonical,
  inLanguage: "pt-BR",
  isPartOf: {
    "@type": "WebSite",
    name: `${siteConfig.name} · ${siteConfig.title}`,
    url: siteConfig.canonical,
  },
  about: {
    "@type": "MedicalCondition",
    name: "Síndrome do olho seco",
    alternateName: [
      "Dry eye disease",
      "Doença da superfície ocular",
      "Ocular Surface Disease Index",
      "OSDI",
    ],
  },
  reviewedBy: {
    "@type": "Physician",
    name: siteConfig.name,
    url: siteConfig.canonical,
  },
  lastReviewed: new Date().toISOString().split("T")[0],
  specialty: {
    "@type": "MedicalSpecialty",
    name: "Ophthalmology",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Como usar a calculadora de olho seco online",
  description:
    "Passo a passo para preencher o questionário de olho seco (OSDI), uma pergunta por vez, e entender o resultado na escala 0–100.",
  totalTime: "PT5M",
  step: howToSteps.map((s, i) => ({
    "@type": "HowToStep",
    position: i + 1,
    name: s.name,
    text: s.text,
  })),
};

const allSchemas = [
  breadcrumbSchema,
  webAppSchema,
  medicalPageSchema,
  howToSchema,
  faqSchema,
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogType="article"
>
  <Fragment slot="head">
    {
      allSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <meta name="subject" content="Calculadora de olho seco" />
    <meta name="topic" content="Oftalmologia — Olho seco e superfície ocular" />
    <meta name="classification" content="Health" />
    <meta name="category" content="Saúde - Oftalmologia" />
    <link rel="preconnect" href="https://api.whatsapp.com" />
  </Fragment>

  <Header />

  <main
    id="conteudo-principal"
    tabindex="-1"
    class="relative mx-auto max-w-3xl overflow-x-clip pt-4 sm:pt-6"
  >
    <nav aria-label="Breadcrumb" class="px-4 pt-4 pb-2">
      <ol class="flex items-center gap-1 text-xs text-muted-foreground">
        <li>
          <a href="/" class="transition-colors hover:text-foreground">Início</a>
        </li>
        <li aria-hidden="true" class="select-none">/</li>
        <li>
          <span class="font-medium text-foreground" aria-current="page"
            >Calculadora de olho seco</span
          >
        </li>
      </ol>
    </nav>

    <div class="olho-seco-app-wrapper min-h-[48dvh]">
      <OsdiCalculator client:only="react" />
      <div
        class="olho-seco-skeleton flex min-h-[48dvh] flex-col items-center justify-center gap-6 px-4 py-8"
      >
        <div class="max-w-md space-y-3 text-center">
          <div class="mx-auto h-7 w-56 animate-pulse rounded-lg bg-muted"></div>
          <div class="mx-auto h-4 w-full max-w-sm animate-pulse rounded bg-muted"></div>
        </div>
        <div class="grid w-full max-w-lg gap-3">
          {
            [1, 2, 3].map(() => (
              <div class="h-24 animate-pulse rounded-xl border border-muted bg-muted/20" />
            ))
          }
        </div>
      </div>
    </div>

    <article class="space-y-12 px-4 py-12">
      <header class="space-y-4 text-center">
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
          Calculadora de olho seco online
        </h1>
        <p
          class="mx-auto max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base"
        >
          Esta ferramenta mede o impacto dos <strong class="text-foreground"
            >sintomas de olho seco</strong
          > na última semana com base no <strong class="text-foreground"
            >questionário OSDI</strong
          > (Ocular Surface Disease Index), usado em estudos e consultas para a <strong
            class="text-foreground">doença da superfície ocular</strong
          >. É uma triagem educativa, alinhada ao instrumento original e à fórmula publicada na
          literatura.
        </p>
        <p class="mx-auto max-w-2xl text-sm text-muted-foreground">
          Ferramenta orientativa, sem substituir exame com oftalmologista.
        </p>
      </header>

      <section class="space-y-4" id="sintomas-e-contexto">
        <h2 class="text-center text-xl font-bold tracking-tight sm:text-2xl">
          Sintomas de olho seco e contexto clínico
        </h2>
        <div
          class="mx-auto max-w-2xl space-y-4 text-sm leading-relaxed text-muted-foreground"
        >
          <p>
            Os sintomas mais buscados por pacientes — como <strong class="text-foreground"
              >ardor</strong
            >, <strong class="text-foreground">sensação de areia</strong>,
            <strong class="text-foreground">fotofobia</strong> (sensibilidade à luz),
            <strong class="text-foreground">visão embaçada</strong> que oscila ao piscar e
            <strong class="text-foreground">cansaço visual</strong> em leitura ou telas — podem
            integrar o espectro do olho seco, mas também outras condições. Por isso o questionário é
            um complemento à anamnese, não um substituto do exame.
          </p>
          <p>
            O <strong class="text-foreground">lacrimejamento excessivo</strong> pode parecer
            contraditório, mas é frequente quando há instabilidade do filme lacrimal ou irritação
            superficial: o olho reage com lágrima reflexa. Na consulta, o especialista avalia também
            <strong class="text-foreground">pálpebras</strong> (por exemplo,
            <strong class="text-foreground">blefarite</strong> ou disfunção das glândulas de Meibômio),
            uso de <strong class="text-foreground">lentes de contato</strong>, medicamentos e hábitos
            de tela.
          </p>
          <p>
            <strong class="text-foreground">Distúrbios do sono</strong>, incluindo
            <strong class="text-foreground"> apneia obstrutiva do sono</strong>, e noites mal
            reparadoras aparecem cada vez mais em estudos como fatores associados a sintomas oculares
            e padrões inflamatórios. Da mesma forma, <strong class="text-foreground">estresse</strong
            > prolongado e <strong class="text-foreground">ansiedade</strong> podem alterar piscar,
            postura no trabalho e percepção de desconforto. Nada disso substitui avaliação médica, mas
            ajuda a montar um histórico completo.
          </p>
          <p>
            <strong class="text-foreground">Dor ocular</strong> leve a moderada pode acompanhar o
            olho seco, porém dor intensa, súbita, com queda de visão ou trauma exige avaliação
            urgente. Se suas queixas forem persistentes, o próximo passo é agendar consulta
            oftalmológica para exame de biomicroscopia e conduta personalizada.
          </p>
        </div>
      </section>

      <section class="space-y-8" id="como-funciona-escala">
        <div class="space-y-2 text-center">
          <h2 class="text-xl font-bold tracking-tight sm:text-2xl">
            Como funciona o resultado (escala OSDI)
          </h2>
          <p class="text-sm text-muted-foreground">
            Baseado no questionário OSDI e na fórmula publicada (Schiffman et al., 2000)
          </p>
        </div>
        <ol class="relative mx-auto max-w-xl space-y-0">
          {
            howToSteps.map((step, i) => (
              <li class="relative flex gap-5 pb-8 last:pb-0">
                {i < howToSteps.length - 1 && (
                  <div
                    class="absolute top-10 bottom-0 left-[19px] w-px bg-border"
                    aria-hidden="true"
                  />
                )}
                <div class="relative z-10 flex size-10 shrink-0 items-center justify-center rounded-full border-2 border-brand bg-brand/10 text-sm font-bold text-brand">
                  {i + 1}
                </div>
                <div class="flex flex-col gap-1 pt-1.5">
                  <h3 class="text-sm font-semibold leading-tight">{step.name}</h3>
                  <p class="text-sm leading-relaxed text-muted-foreground">{step.text}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="space-y-6" id="faq-olho-seco">
        <h2 class="text-center text-xl font-bold tracking-tight sm:text-2xl">
          Perguntas frequentes (olho seco, sintomas e questionário)
        </h2>
        <div
          class="mx-auto max-w-2xl divide-y divide-border rounded-xl border border-border"
        >
          {
            faqItems.map((item) => (
              <details class="group px-5 py-4">
                <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-foreground [&::-webkit-details-marker]:hidden">
                  <span class="pr-4">{item.question}</span>
                  <svg
                    class="size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m19 9-7 7-7-7"
                    />
                  </svg>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.answer}</p>
              </details>
            ))
          }
        </div>
      </section>

      <ScheduleConsultationSection
        id="agendar"
        title="Agende avaliação para olho seco e superfície ocular"
        description="A calculadora ajuda a organizar suas queixas, mas o diagnóstico e o plano terapêutico —lágrimas artificiais, higiene das pálpebras, ajuste de lentes, tratamentos anti-inflamatórios ou outros— dependem do exame. Agende consulta com Leonardo Nunes em Fortaleza ou nas cidades de atendimento."
        whatsappMessageTemplate="Olá, Dr. Leonardo! Usei a calculadora de olho seco no site e gostaria de agendar avaliação em {city}."
        triggerLabel="Agendar consulta"
        triggerGtmId="gtm-page-olho-seco-schedule-whatsapp"
        agendaLinkGtmId="gtm-page-olho-seco-schedule-agenda"
        onlineBookingLinkId="gtm-page-olho-seco-dialog-agendar-online"
      />

      <footer class="space-y-6 border-t border-border pt-8">
        <div
          class="mx-auto max-w-2xl rounded-lg border border-amber-500/20 bg-amber-500/5 p-4"
        >
          <p class="text-center text-xs leading-relaxed text-muted-foreground">
            <strong>Aviso médico:</strong> O questionário OSDI é instrumento clínico validado; esta
            calculadora é para fins educativos e não substitui avaliação presencial. Referência:
            Schiffman RM et al. Reliability and validity of the Ocular Surface Disease Index. Arch
            Ophthalmol. 2000;118:615-621. O nome OSDI e materiais originais são de titularidade dos
            respectivos detentores de direitos.
          </p>
        </div>
        <nav
          aria-label="Links relacionados"
          class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-muted-foreground"
        >
          <a href="/" class="transition-colors hover:text-foreground">Página Inicial</a>
          <a href="/#atuacao" class="transition-colors hover:text-foreground">Especialidades</a>
          <a href="/#atendimento" class="transition-colors hover:text-foreground"
            >Cidades de Atendimento</a
          >
          <a href="/acuidade-visual" class="transition-colors hover:text-foreground"
            >Teste de Acuidade Visual</a
          >
          <a href="/tela-de-amsler" class="transition-colors hover:text-foreground"
            >Tela de Amsler</a
          >
          <a href="/conteudos" class="transition-colors hover:text-foreground">Conteúdos</a>
        </nav>
      </footer>
    </article>
  </main>
  <Footer />
</Layout>

<style is:global>
  .olho-seco-app-wrapper:has(astro-island > *) .olho-seco-skeleton {
    display: none;
  }
</style>
