---
import { siteConfig } from "@/config/site";

interface Props {
  includeFAQ?: boolean;
}

const { includeFAQ = false } = Astro.props as Props;

const ogImageURL = new URL(siteConfig.meta.ogImage, siteConfig.canonical).href;
const logoURL = new URL("/favicon/favicon.svg", siteConfig.canonical).href;

const physicianSchema = {
  "@context": "https://schema.org",
  "@type": "Physician",
  name: `${siteConfig.name}`,
  description: siteConfig.meta.description,
  url: siteConfig.canonical,
  image: ogImageURL,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  medicalSpecialty: ["Ophthalmology"],
  availableService: siteConfig.services.map((s) => ({
    "@type": "MedicalProcedure",
    name: s.title,
    description: s.shortDescription,
  })),
  areaServed: siteConfig.cities.map((c) => ({
    "@type": "City",
    name: `${c.name}, ${c.state}`,
  })),
};

const medicalBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  name: `${siteConfig.name} · ${siteConfig.title}`,
  description: siteConfig.meta.description,
  url: siteConfig.canonical,
  image: ogImageURL,
  logo: logoURL,
  telephone: siteConfig.phone,
  priceRange: "$$",
  medicalSpecialty: "Ophthalmology",
};

const localBusinessSchemas = siteConfig.cities.map((city) => ({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteConfig.canonical}/#${city.slug}`,
  name: `${siteConfig.name} · ${siteConfig.title} em ${city.name}`,
  description: `Oftalmologista em ${city.name}, ${city.state}. Consulta oftalmológica, cirurgia de catarata e tratamento de retina.`,
  url: siteConfig.canonical,
  image: ogImageURL,
  logo: logoURL,
  telephone: siteConfig.phone,
  address: {
    "@type": "PostalAddress",
    addressLocality: city.name,
    addressRegion: city.state,
    addressCountry: "BR",
  },
  areaServed: {
    "@type": "City",
    name: city.name,
  },
  priceRange: "$$",
}));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: siteConfig.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: `${siteConfig.name} · ${siteConfig.title}`,
  url: siteConfig.canonical,
  description: siteConfig.meta.description,
  image: ogImageURL,
  inLanguage: "pt-BR",
};

const allSchemas = [
  physicianSchema,
  medicalBusinessSchema,
  ...localBusinessSchemas,
  ...(includeFAQ ? [faqSchema] : []),
  websiteSchema,
];
---

{allSchemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
