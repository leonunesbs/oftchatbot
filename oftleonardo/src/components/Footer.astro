---
/// <reference types="astro/astro-jsx" />
import { siteConfig } from "@/config/site";
---

<footer class="border-t border-border bg-card py-12 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <span
          class="block text-[10px] font-medium uppercase tracking-[0.2em] text-foreground/75"
        >
          Oftalmologista
        </span>
        <span class="text-lg font-semibold tracking-tight text-foreground">
          Leonardo Nunes
        </span>
        <p class="mt-2 text-sm text-foreground/75">
          {siteConfig.crm} · {siteConfig.rqe}
        </p>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-semibold text-foreground">
          Especialidades
        </h3>
        <ul class="space-y-2">
          {
            siteConfig.services.map((service) => (
              <li>
                <a
                  href="#atuacao"
                  class="text-sm text-foreground/75 transition-colors hover:text-foreground"
                >
                  {service.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-semibold text-foreground">
          Cidades de Atendimento
        </h3>
        <ul class="space-y-2">
          {
            siteConfig.cities.map((city) => (
              <li class="text-sm text-foreground/75">
                {city.name} – {city.state}
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-semibold text-foreground">Links</h3>
        <ul class="space-y-2">
          {
            siteConfig.navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-foreground/75 transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="/termos-de-uso"
              class="text-sm text-foreground/75 transition-colors hover:text-foreground"
            >
              Termos de Uso
            </a>
          </li>
          <li>
            <a
              href="/politica-de-privacidade"
              class="text-sm text-foreground/75 transition-colors hover:text-foreground"
            >
              Política de Privacidade
            </a>
          </li>
          <li>
            <a
              href="/conteudos"
              class="text-sm text-foreground/75 transition-colors hover:text-foreground"
            >
              Hub de Conteúdos
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="my-8 h-px w-full bg-border" aria-hidden="true"></div>

    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-xs text-foreground/75">
        &copy; {new Date().getFullYear()}
        {siteConfig.name} – {siteConfig.title}. Todos os direitos reservados.
      </p>
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-3">
          <a
            href={siteConfig.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-foreground/75 transition-colors hover:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a
            href={siteConfig.social.threads}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Threads"
            class="text-foreground/75 transition-colors hover:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"/></svg>
          </a>
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-foreground/75 transition-colors hover:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a
            href={siteConfig.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="text-foreground/75 transition-colors hover:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a
            href={siteConfig.social.x}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter)"
            class="text-foreground/75 transition-colors hover:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
        <span class="text-xs text-foreground/75">
          {siteConfig.domains.join(" · ")}
        </span>
      </div>
    </div>

    <div class="mt-4 text-center">
      <p class="text-[10px] text-foreground/80">
        Este site respeita a Lei Geral de Proteção de Dados (LGPD – Lei
        13.709/2018). As informações aqui apresentadas têm caráter informativo e
        não substituem uma consulta médica.
      </p>
    </div>
  </div>
</footer>
