---
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import { siteConfig } from "@/config/site";
import { cn } from "@/lib/utils";
---

<section id="section-hero" class="relative">
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(80%_60%_at_50%_0%,color-mix(in_oklch,var(--color-brand)_12%,transparent),transparent),radial-gradient(50%_50%_at_100%_100%,color-mix(in_oklch,var(--color-brand)_8%,transparent),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32 lg:py-40">
    <div class="mx-auto max-w-3xl text-center">
      <Badge
        variant="secondary"
        className="home-hero-in mb-6 gap-1.5 px-3 py-1 text-xs font-medium tracking-wide"
      >
        Médico Oftalmologista · Retina e Catarata
      </Badge>

      <h1 class="text-foreground">
        <span
          class="home-hero-in home-hero-in-delay-1 block text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl"
        >
          Leonardo Nunes
        </span>
        <span
          class="home-hero-in home-hero-in-delay-2 mt-3 block text-lg font-medium tracking-tight text-brand sm:text-xl lg:text-2xl"
        >
          {siteConfig.hero.headline}
        </span>
      </h1>

      <p
        class="home-hero-in home-hero-in-delay-3 mt-6 text-lg leading-relaxed text-muted-foreground max-sm:text-foreground/90 dark:max-sm:text-muted-foreground sm:text-xl"
      >
        {siteConfig.hero.subheadline}
      </p>

      <div
        class="home-hero-in home-hero-in-delay-4 mt-10 flex flex-wrap items-center justify-center gap-3"
      >
        <button
          type="button"
          data-booking-trigger
          data-url-sync="true"
          id="gtm-hero-booking"
          data-online-booking-link-id="gtm-hero-dialog-agendar-online"
          class={cn(
            buttonVariants({ variant: "default", size: "lg" }),
            "h-12 px-8 text-base",
          )}
        >
          Agendar Consulta
        </button>
        <a
          id="gtm-hero-ver-especialidades"
          href="#atuacao"
          data-section-scroll
          class={`${buttonVariants({ variant: "outline", size: "lg" })} h-12 px-8 text-base`}
        >
          Ver Especialidades
        </a>
      </div>

      <div
        class="home-hero-in home-hero-in-delay-5 mt-16 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground max-sm:text-foreground/88 dark:max-sm:text-muted-foreground"
      >
        {
          siteConfig.cities.map((city) => (
            <span class="flex items-center gap-1.5">
              <span class="size-1.5 rounded-full bg-brand/60" />
              {city.name} – {city.state}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
