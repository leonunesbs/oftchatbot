---
import { Badge } from "@/components/ui/badge";
import { siteConfig } from "@/config/site";
import AnimatedSection from "./AnimatedSection";
import WhatsAppModal from "./WhatsAppModal";
---

<section class="relative">
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(80%_60%_at_50%_0%,color-mix(in_oklch,var(--color-brand)_12%,transparent),transparent),radial-gradient(50%_50%_at_100%_100%,color-mix(in_oklch,var(--color-brand)_8%,transparent),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32 lg:py-40">
    <div class="mx-auto max-w-3xl text-center">
      <AnimatedSection client:idle mode="none">
        <Badge
          variant="secondary"
          className="mb-6 gap-1.5 px-3 py-1 text-xs font-medium tracking-wide"
        >
          Médico Oftalmologista · Retina e Catarata
        </Badge>
      </AnimatedSection>

      <AnimatedSection client:idle mode="none">
        <h1 class="text-foreground">
          <span
            class="block text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl"
          >
            Leonardo Nunes
          </span>
          <span
            class="mt-3 block text-lg font-medium tracking-tight text-brand sm:text-xl lg:text-2xl"
          >
            {siteConfig.hero.headline}
          </span>
        </h1>
      </AnimatedSection>

      <AnimatedSection client:idle mode="none">
        <p
          class="mt-6 text-lg leading-relaxed text-muted-foreground sm:text-xl"
        >
          {siteConfig.hero.subheadline}
        </p>
      </AnimatedSection>

      <AnimatedSection client:idle mode="none">
        <div
          class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
        >
          <WhatsAppModal
            client:idle
            size="lg"
            className="h-12 rounded-full px-8 text-base font-medium"
          >
            Agendar Consulta
          </WhatsAppModal>
          <a
            href="#atuacao"
            class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          >
            Conheça as especialidades &darr;
          </a>
        </div>
      </AnimatedSection>

      <AnimatedSection client:idle mode="none">
        <div
          class="mt-16 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground"
        >
          {
            siteConfig.cities.map((city) => (
              <span class="flex items-center gap-1.5">
                <span class="size-1.5 rounded-full bg-brand/60" />
                {city.name} – {city.state}
              </span>
            ))
          }
        </div>
      </AnimatedSection>
    </div>
  </div>
</section>
