---
import { Picture } from "astro:assets";
import { siteConfig } from "@/config/site";
import WhatsAppModal from "./WhatsAppModal";
import { Separator } from "@/components/ui/separator";
import { MapPin, Camera } from "lucide-react";

import foto1 from "@/assets/foto-1.jpeg";
import foto2 from "@/assets/foto-2.jpeg";
import foto3 from "@/assets/foto-3.jpeg";

const cityImages: Record<string, ImageMetadata> = {
  "fortaleza": foto1,
  "sao-domingos-do-maranhao": foto2,
  "fortuna-ma": foto3,
};

const imageStyles: Record<string, string> = {
  "fortaleza": "scale-[1.25] object-[20%_30%]",
};
---

<section id="atendimento" class="bg-secondary/30 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="scroll-reveal mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Cidades de Atendimento
      </h2>
      <p class="mt-4 text-muted-foreground">
        O mesmo padrão de excelência, tecnologia e dedicação em cada cidade de atendimento.
      </p>
    </div>

    <div class="scroll-3d-stage mt-14 grid gap-8 lg:grid-cols-3">
      {siteConfig.cities.map((city) => {
        const importedImage = cityImages[city.slug];
        return (
          <div class="surface-lift scroll-card-depth scroll-card-motion group flex h-full flex-col overflow-hidden rounded-2xl border border-border/50 bg-card hover:border-border hover:shadow-md">
              {/* Photo area */}
              <div class="relative aspect-16/10 w-full overflow-hidden bg-secondary/60">
                {importedImage ? (
                  <Picture
                    src={importedImage}
                    alt={city.imageAlt}
                    widths={[640, 800, 1200]}
                    sizes="(min-width: 1024px) 33vw, 100vw"
                    formats={["avif", "webp", "jpeg"]}
                    class={`h-full w-full transform-gpu object-cover transition-transform duration-500 group-hover:scale-[1.03] ${imageStyles[city.slug] || ""}`}
                  />
                ) : city.image ? (
                  <img
                    src={city.image}
                    alt={city.imageAlt}
                    width={800}
                    height={500}
                    loading="lazy"
                    decoding="async"
                    class={`h-full w-full transform-gpu object-cover transition-transform duration-500 group-hover:scale-[1.03] ${imageStyles[city.slug] || ""}`}
                  />
                ) : (
                  <div class="flex h-full w-full flex-col items-center justify-center gap-3 bg-linear-to-br from-secondary/80 via-secondary/40 to-brand/6">
                    <div class="flex size-16 items-center justify-center rounded-2xl bg-brand/10 text-brand/50">
                      <Camera className="size-7" />
                    </div>
                    <span class="max-w-[200px] text-center text-xs leading-relaxed text-foreground/75">
                      {city.imageSuggestion}
                    </span>
                  </div>
                )}
                <div class="absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-card to-transparent" />
              </div>

              {/* Content */}
              <div class="flex flex-1 flex-col p-5 sm:p-6">
                <div class="mb-3 flex items-start gap-3">
                  <span class="flex size-10 shrink-0 items-center justify-center rounded-xl bg-brand/10 text-brand">
                    <MapPin className="size-5" />
                  </span>
                  <div class="min-w-0">
                    <h3 class="text-base font-semibold leading-snug text-foreground sm:text-lg">
                      {city.name}
                    </h3>
                    <span class="text-sm text-muted-foreground">{city.state}</span>
                  </div>
                </div>

                <Separator className="mb-4" />

                <p class="flex-1 text-sm leading-relaxed text-muted-foreground">
                  {city.description}
                </p>

                <div class="relative z-10 mt-6">
                  <WhatsAppModal
                    client:visible
                    variant="outline"
                    size="sm"
                    className="w-full"
                    triggerId={`gtm-cities-${city.slug}-booking`}
                    onlineBookingLinkId={`gtm-cities-${city.slug}-dialog-agendar-online`}
                  >
                    Agendar consulta
                  </WhatsAppModal>
                </div>
              </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
