---
import { buttonVariants } from "@/components/ui/button";
import { siteConfig } from "@/config/site";
import type { CollectionEntry } from "astro:content";
import { ArrowRight, BookOpen, Eye, Sparkles } from "lucide-react";

interface Props {
  cityName: string;
  items: CollectionEntry<"conteudos">[];
  /** Guia de presbiopia em vitrine acima da grade (opcional). */
  presbiopiaSpotlight?: CollectionEntry<"conteudos"> | null;
  /** Guia sobre lentes premium na catarata em vitrine (opcional). */
  premiumLensesSpotlight?: CollectionEntry<"conteudos"> | null;
}

const { cityName, items, presbiopiaSpotlight, premiumLensesSpotlight } =
  Astro.props;

const hasSpotlightAboveGrid = Boolean(
  presbiopiaSpotlight || premiumLensesSpotlight,
);

/** Dois destaques: layout mais compacto em colunas; um só: cartão hero em largura total. */
const bothSpotlights = Boolean(
  presbiopiaSpotlight && premiumLensesSpotlight,
);

const spotlightCount =
  Number(Boolean(presbiopiaSpotlight)) +
  Number(Boolean(premiumLensesSpotlight));

/**
 * Fundo dos cards em destaque: gradiente diagonal sutil alinhado à cor da categoria do hub
 * (mesma família dos badges em /conteudos).
 */
const spotlightCardGradient = {
  conditions:
    "from-sky-500/[0.06] via-[42%] via-transparent to-brand/[0.035] dark:from-sky-400/[0.075] dark:via-transparent dark:to-brand/[0.045]",
  refractive:
    "from-amber-500/[0.06] via-[42%] via-transparent to-brand/[0.035] dark:from-amber-400/[0.075] dark:via-transparent dark:to-brand/[0.045]",
  exams:
    "from-violet-500/[0.055] via-[42%] via-transparent to-brand/[0.035] dark:from-violet-400/[0.08] dark:via-transparent dark:to-brand/[0.045]",
} as const;

/** Mesmas cores dos cards em /conteudos (hub por tipo). */
const hubBadgeClass = {
  conditions:
    "border-sky-500/25 bg-sky-500/10 text-sky-700 dark:text-sky-400",
  refractive:
    "border-amber-500/25 bg-amber-500/10 text-amber-800 dark:text-amber-400",
  exams:
    "border-violet-500/20 bg-violet-500/10 text-violet-600 dark:text-violet-400",
} as const;

const hubBadgeLabel = {
  conditions: "Guia",
  refractive: "Refração",
  exams: "Referência",
} as const;
---

<section
  id="conteudos-educativos"
  aria-labelledby="heading-conteudos-home"
  class="relative scroll-mt-28 py-24 sm:py-32"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-[min(55vh,480px)] bg-gradient-to-b from-brand/[0.055] via-brand/[0.018] to-transparent dark:from-muted/25 dark:via-muted/8"
    aria-hidden="true"
  />
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="scroll-reveal mx-auto max-w-3xl text-center">
      <div
        class="mb-5 flex flex-wrap items-center justify-center gap-2 sm:mb-6 sm:gap-3"
      >
        <span
          class="inline-flex items-center gap-2 rounded-full border border-border/80 bg-background/95 px-3 py-1 text-xs font-semibold tracking-wide text-foreground shadow-[0_1px_2px_rgba(0,0,0,0.05)] ring-1 ring-black/[0.06] dark:border-brand/25 dark:bg-brand/10 dark:text-brand dark:shadow-none dark:ring-0"
        >
          <BookOpen className="size-3.5 text-brand dark:opacity-90" aria-hidden="true" />
          Conteúdo educativo
        </span>
        <span
          class="inline-flex items-center rounded-full border border-border/70 bg-background/90 px-3 py-1 text-xs font-medium tracking-wide text-muted-foreground shadow-[0_1px_2px_rgba(0,0,0,0.04)] backdrop-blur-sm dark:border-white/10 dark:bg-zinc-900/35 dark:text-zinc-300 dark:shadow-none"
        >
          Revisão clínica
        </span>
      </div>
      <h2
        id="heading-conteudos-home"
        class="text-balance font-bold tracking-tight text-foreground text-[clamp(1.75rem,4.6vw,2.75rem)] leading-[1.08]"
      >
        Guias e referências em oftalmologia
      </h2>
      <p
        class="mx-auto mt-5 max-w-2xl text-pretty text-base leading-relaxed text-foreground/88 sm:mt-6 sm:text-lg dark:text-muted-foreground"
      >
        Textos claros sobre doenças oculares, refração e exames — para você chegar à consulta com mais
        segurança e perguntas melhores. Os guias são gerais e ajudam a entender o que costuma ser avaliado
        no consultório, em qualquer cidade.
      </p>
      <p
        class="mx-auto mt-4 max-w-2xl text-pretty text-xs leading-relaxed text-foreground/72 sm:text-sm dark:text-muted-foreground/85"
      >
        Informação de educação em saúde: não substitui avaliação presencial nem diagnóstico individual.
      </p>
    </div>

    {
      hasSpotlightAboveGrid && (
        <div
          class="scroll-reveal mt-14 sm:mt-16"
          role="region"
          aria-labelledby="heading-home-conteudos-destaques"
          aria-describedby="home-spotlight-deck-desc"
        >
          <div class="mx-auto flex max-w-xl flex-col items-center text-center">
            <p
              class="text-[0.7rem] font-medium tabular-nums tracking-wide text-muted-foreground/90 sm:text-xs"
            >
              {spotlightCount === 2
                ? "2 guias · leitura estimada em cada card"
                : "1 guia · leitura estimada no card"}
            </p>
            <h3
              id="heading-home-conteudos-destaques"
              class="text-balance mt-2.5 font-semibold tracking-tight text-foreground text-[1.125rem] leading-snug sm:mt-3 sm:text-xl"
            >
              Guias em destaque
            </h3>
            <div
              class="mt-3 h-px w-10 shrink-0 bg-gradient-to-r from-transparent via-border to-transparent sm:mt-3.5 sm:w-12"
              aria-hidden="true"
            />
            <p
              id="home-spotlight-deck-desc"
              class="mt-3.5 max-w-[22rem] text-pretty text-sm leading-relaxed text-muted-foreground sm:mt-4 sm:max-w-none sm:text-[0.9375rem]"
            >
              Temas que costumam gerar muitas dúvidas, em linguagem direta — ajuda a preparar a
              consulta, sem substituir avaliação presencial nem diagnóstico.
            </p>
          </div>
          <div
            class:list={[
              "mt-8 grid gap-6 sm:mt-9 sm:gap-7",
              bothSpotlights ? "lg:grid-cols-2 lg:items-stretch lg:gap-8" : "",
            ]}
          >
            {presbiopiaSpotlight && (
              <a
                href={`/conteudos/${presbiopiaSpotlight.id}`}
                id="gtm-home-conteudo-presbiopia-spotlight"
                class:list={[
                  "surface-lift group relative flex min-h-[11rem] flex-col overflow-hidden rounded-xl border border-border/55 bg-card p-6 shadow-[0_24px_64px_-36px_rgba(0,0,0,0.18)] outline-none ring-1 ring-black/[0.04] transition-[transform,box-shadow,border-color] duration-500 hover:border-brand/35 hover:shadow-[0_32px_72px_-32px_rgba(0,0,0,0.22)] focus-visible:ring-2 focus-visible:ring-brand/45 focus-visible:ring-offset-2 focus-visible:ring-offset-background dark:border-border dark:shadow-[0_24px_64px_-36px_rgba(0,0,0,0.55)] dark:ring-white/[0.06] dark:hover:border-brand/40 sm:min-h-0 sm:p-8",
                  bothSpotlights ? "h-full" : "min-h-0 lg:min-h-[12rem]",
                ]}
              >
                <div
                  class:list={[
                    "pointer-events-none absolute inset-0 bg-gradient-to-br",
                    spotlightCardGradient.refractive,
                  ]}
                  aria-hidden="true"
                />
                <div
                  class:list={[
                    "relative z-[1] flex min-w-0 flex-1 flex-col",
                    bothSpotlights ? "" : "lg:flex-row lg:items-center lg:gap-10 xl:gap-12",
                  ]}
                >
                  <div class:list={["min-w-0 flex-1", bothSpotlights ? "" : "lg:flex-1"]}>
                    <div class="flex flex-wrap items-center gap-2 sm:gap-2.5">
                      <span class="inline-flex items-center rounded-full border border-amber-500/25 bg-amber-500/10 px-3 py-1 text-xs font-medium tracking-wide text-amber-800 dark:text-amber-400">
                        Refração
                      </span>
                      <span class="inline-flex items-center rounded-full border border-border/60 bg-muted/35 px-3 py-1 text-xs font-medium tabular-nums text-muted-foreground">
                        {presbiopiaSpotlight.data.readingTime}
                      </span>
                    </div>
                    <div
                      class:list={[
                        "mt-4 flex items-start gap-3.5 sm:mt-5 sm:gap-4",
                        bothSpotlights ? "flex-col sm:flex-row" : "",
                      ]}
                    >
                      <span
                        class="mt-0.5 flex size-10 shrink-0 items-center justify-center rounded-lg border border-brand/20 bg-brand/[0.08] text-brand sm:size-11 dark:bg-brand/15"
                        aria-hidden="true"
                      >
                        <Eye className="size-[1.15rem] sm:size-5" />
                      </span>
                      <div class="min-w-0">
                        <h4
                          class="text-pretty text-lg font-semibold leading-tight tracking-tight text-foreground sm:text-xl sm:leading-snug"
                        >
                          Vista cansada após os 40? Entenda a presbiopia
                        </h4>
                        <p
                          class="mt-2.5 max-w-2xl text-pretty text-sm leading-relaxed text-muted-foreground line-clamp-4 sm:mt-3 sm:text-base lg:line-clamp-none"
                        >
                          Dificuldade para ler e para focar no celular de perto, com sensação de braço curto?
                          Entenda o que muda no olho e quais opções existem, de óculos a cirurgia, com
                          orientação clínica clara.
                        </p>
                      </div>
                    </div>
                  </div>
                  <div
                    class:list={[
                      "relative z-[1] flex shrink-0 flex-col pt-6",
                      bothSpotlights ? "mt-auto" : "lg:mt-0 lg:shrink-0 lg:pt-0",
                    ]}
                  >
                    <span
                      class:list={[
                        "inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-brand/35 bg-brand px-5 py-3.5 text-sm font-semibold text-brand-foreground shadow-sm transition-colors duration-300 group-hover:bg-brand/92 sm:px-6",
                        bothSpotlights ? "w-full" : "w-full lg:w-auto lg:min-w-[12rem]",
                      ]}
                    >
                      Ler guia
                      <ArrowRight
                        className="size-4 transition-transform duration-300 group-hover:translate-x-0.5"
                        aria-hidden="true"
                      />
                    </span>
                  </div>
                </div>
              </a>
            )}
            {premiumLensesSpotlight && (
              <a
                href={`/conteudos/${premiumLensesSpotlight.id}`}
                id="gtm-home-conteudo-lentes-premium-spotlight"
                class:list={[
                  "surface-lift group relative flex min-h-[11rem] flex-col overflow-hidden rounded-xl border border-border/55 bg-card p-6 shadow-[0_24px_64px_-36px_rgba(0,0,0,0.18)] outline-none ring-1 ring-black/[0.04] transition-[transform,box-shadow,border-color] duration-500 hover:border-brand/35 hover:shadow-[0_32px_72px_-32px_rgba(0,0,0,0.22)] focus-visible:ring-2 focus-visible:ring-brand/45 focus-visible:ring-offset-2 focus-visible:ring-offset-background dark:border-border dark:shadow-[0_24px_64px_-36px_rgba(0,0,0,0.55)] dark:ring-white/[0.06] dark:hover:border-brand/40 sm:min-h-0 sm:p-8",
                  bothSpotlights ? "h-full" : "min-h-0 lg:min-h-[12rem]",
                ]}
              >
                <div
                  class:list={[
                    "pointer-events-none absolute inset-0 bg-gradient-to-br",
                    spotlightCardGradient[premiumLensesSpotlight.data.hubCategory],
                  ]}
                  aria-hidden="true"
                />
                <div
                  class:list={[
                    "relative z-[1] flex min-w-0 flex-1 flex-col",
                    bothSpotlights ? "" : "lg:flex-row lg:items-center lg:gap-10 xl:gap-12",
                  ]}
                >
                  <div class:list={["min-w-0 flex-1", bothSpotlights ? "" : "lg:flex-1"]}>
                    <div class="flex flex-wrap items-center gap-2 sm:gap-2.5">
                      <span
                        class:list={[
                          "inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium tracking-wide",
                          hubBadgeClass[premiumLensesSpotlight.data.hubCategory],
                        ]}
                      >
                        {hubBadgeLabel[premiumLensesSpotlight.data.hubCategory]}
                      </span>
                      <span class="inline-flex items-center rounded-full border border-border/60 bg-muted/35 px-3 py-1 text-xs font-medium tabular-nums text-muted-foreground">
                        {premiumLensesSpotlight.data.readingTime}
                      </span>
                    </div>
                    <div
                      class:list={[
                        "mt-4 flex items-start gap-3.5 sm:mt-5 sm:gap-4",
                        bothSpotlights ? "flex-col sm:flex-row" : "",
                      ]}
                    >
                      <span
                        class="mt-0.5 flex size-10 shrink-0 items-center justify-center rounded-lg border border-brand/20 bg-brand/[0.08] text-brand sm:size-11 dark:bg-brand/15"
                        aria-hidden="true"
                      >
                        <Sparkles className="size-[1.15rem] sm:size-5" />
                      </span>
                      <div class="min-w-0">
                        <h4
                          class="text-pretty text-lg font-semibold leading-tight tracking-tight text-foreground sm:text-xl sm:leading-snug"
                        >
                          {premiumLensesSpotlight.data.title}
                        </h4>
                        <p
                          class="mt-2.5 text-pretty text-sm leading-relaxed text-muted-foreground line-clamp-3 sm:mt-3 sm:text-base lg:line-clamp-4"
                        >
                          {premiumLensesSpotlight.data.description}
                        </p>
                      </div>
                    </div>
                  </div>
                  <div
                    class:list={[
                      "relative z-[1] flex shrink-0 flex-col pt-6",
                      bothSpotlights ? "mt-auto" : "lg:mt-0 lg:shrink-0 lg:pt-0",
                    ]}
                  >
                    <span
                      class:list={[
                        "inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-brand/35 bg-brand px-5 py-3.5 text-sm font-semibold text-brand-foreground shadow-sm transition-colors duration-300 group-hover:bg-brand/92 sm:px-6",
                        bothSpotlights ? "w-full" : "w-full lg:w-auto lg:min-w-[12rem]",
                      ]}
                    >
                      Ler guia
                      <ArrowRight
                        className="size-4 transition-transform duration-300 group-hover:translate-x-0.5"
                        aria-hidden="true"
                      />
                    </span>
                  </div>
                </div>
              </a>
            )}
          </div>
        </div>
      )
    }

    <div
      class:list={[
        "scroll-3d-stage grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 lg:gap-7",
        hasSpotlightAboveGrid ? "mt-12 sm:mt-14" : "mt-14 sm:mt-16",
      ]}
    >
      {
        items.map((article) => {
          const hubKey = article.data.hubCategory;
          const badgeTone = hubBadgeClass[hubKey];
          const badgeText = hubBadgeLabel[hubKey];
          return (
            <article
              class="surface-lift scroll-card-depth scroll-card-motion group relative h-full overflow-hidden rounded-xl border border-border/40 bg-card/95 shadow-[0_1px_0_0_rgba(0,0,0,0.05)] transition-[box-shadow,border-color] duration-300 hover:border-border/70 hover:shadow-[0_16px_48px_-28px_rgba(0,0,0,0.14)] dark:shadow-[0_1px_0_0_rgba(255,255,255,0.06)] dark:hover:shadow-[0_20px_56px_-24px_rgba(0,0,0,0.55)]"
            >
              <a
                href={`/conteudos/${article.id}`}
                id={`gtm-home-conteudo-${article.id}`}
                class="flex h-full flex-col rounded-xl p-7 outline-none transition-colors focus-visible:ring-2 focus-visible:ring-brand/40 focus-visible:ring-offset-2 focus-visible:ring-offset-background sm:p-8"
              >
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class:list={[
                      "inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium",
                      badgeTone,
                    ]}
                  >
                    {badgeText}
                  </span>
                  <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2 py-0.5 text-[10px] font-medium text-brand">
                    {article.data.readingTime}
                  </span>
                </div>
                <h3 class="mt-4 text-pretty text-xl font-semibold leading-snug tracking-tight text-foreground transition-colors duration-300 group-hover:text-brand/95 sm:mt-5 sm:text-[1.35rem]">
                  {article.data.condition}
                </h3>
                <p
                  class="mt-3 flex-1 text-pretty text-sm leading-relaxed text-muted-foreground line-clamp-3"
                >
                  {article.data.description}
                </p>
                <span class="mt-7 inline-flex items-center gap-2 text-sm font-medium text-foreground/75 transition-colors duration-300 group-hover:text-foreground">
                  Ler guia
                  <ArrowRight
                    className="size-4 opacity-45 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:opacity-80"
                    aria-hidden="true"
                  />
                </span>
              </a>
            </article>
          );
        })
      }
    </div>

    <div class="mt-14 flex flex-col items-center justify-center gap-3 sm:mt-16 sm:flex-row sm:gap-4">
      <a
        href="/conteudos"
        id="gtm-home-conteudos-hub"
        class={`${buttonVariants({ size: "lg" })} min-h-12 rounded-md px-8 text-base shadow-sm`}
      >
        Ver todos os conteúdos
      </a>
      <a
        href="/agendamento-online"
        id="gtm-home-conteudos-agendar"
        class={`${buttonVariants({ variant: "outline", size: "lg" })} min-h-12 rounded-md px-8 text-base`}
      >
        Agendar consulta
      </a>
    </div>

    <p
      class="mx-auto mt-8 max-w-2xl text-center text-xs leading-relaxed text-muted-foreground/90 sm:mt-10 sm:text-sm"
    >
      Os guias são de autoria de {siteConfig.name}, oftalmologista com ênfase em retina e catarata,
      em linguagem direta para apoiar escolhas conscientes no cuidado com a visão — inclusive em{" "}
      {cityName} e nas demais cidades onde há atendimento.
    </p>
  </div>
</section>
