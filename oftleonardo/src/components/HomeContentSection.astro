---
import { buttonVariants } from "@/components/ui/button";
import { siteConfig } from "@/config/site";
import type { CollectionEntry } from "astro:content";
import { ArrowRight, BookOpen, Eye, Sparkles } from "lucide-react";

interface Props {
  cityName: string;
  items: CollectionEntry<"conteudos">[];
  /** Guia de presbiopia em vitrine acima da grade (opcional). */
  presbiopiaSpotlight?: CollectionEntry<"conteudos"> | null;
}

const { cityName, items, presbiopiaSpotlight } = Astro.props;

const categoryStyles = {
  conditions: {
    label: "Doenças e condições",
    badge:
      "border-sky-500/25 bg-sky-500/10 text-sky-800 dark:text-sky-400",
    ring: "hover:border-sky-500/35 focus-visible:ring-sky-500/55",
  },
  refractive: {
    label: "Refração",
    badge:
      "border-amber-500/25 bg-amber-500/10 text-amber-800 dark:text-amber-400",
    ring: "hover:border-amber-500/40 focus-visible:ring-amber-500/55",
  },
  exams: {
    label: "Exames e diagnóstico",
    badge:
      "border-violet-500/25 bg-violet-500/10 text-violet-700 dark:text-violet-400",
    ring: "hover:border-violet-500/35 focus-visible:ring-violet-500/55",
  },
} as const;
---

<section
  id="conteudos-educativos"
  aria-labelledby="heading-conteudos-home"
  class="scroll-mt-28 py-20 sm:py-28"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="scroll-reveal mx-auto max-w-3xl text-center">
      <div
        class="mb-4 inline-flex items-center gap-2 rounded-full border border-border/60 bg-muted/40 px-3 py-1 text-xs font-medium text-muted-foreground"
      >
        <BookOpen className="size-3.5 text-brand" aria-hidden="true" />
        Conteúdo educativo
        <span class="hidden sm:inline" aria-hidden="true">·</span>
        <span class="hidden sm:inline">Revisão por especialista</span>
      </div>
      <h2
        id="heading-conteudos-home"
        class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
      >
        Guias e referências em oftalmologia
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Textos claros sobre doenças oculares, refração e exames — para você chegar à consulta com mais
        segurança e perguntas melhores. Citamos <strong class="font-semibold text-foreground">{cityName}</strong> como
        referência local quando isso faz sentido para a sua região. Os guias são gerais: ajudam a entender o que
        costuma ser avaliado no consultório, em qualquer cidade.
      </p>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
        Informação de educação em saúde: não substitui avaliação presencial nem diagnóstico individual.
      </p>
    </div>

    {
      presbiopiaSpotlight && (
        <div class="scroll-reveal mt-14">
          <a
            href={`/conteudos/${presbiopiaSpotlight.id}`}
            id="gtm-home-conteudo-presbiopia-spotlight"
            class="surface-lift group relative block overflow-hidden rounded-2xl border-2 border-border bg-card p-6 shadow-lg shadow-black/[0.1] outline-none ring-1 ring-brand/25 transition-[transform,box-shadow,border-color,ring-color] hover:border-brand/55 hover:shadow-xl hover:shadow-black/[0.14] hover:ring-brand/35 dark:border-border dark:shadow-[0_8px_30px_-12px_rgba(0,0,0,0.45)] dark:ring-brand/30 dark:hover:border-brand/50 dark:hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.55)] focus-visible:ring-2 focus-visible:ring-brand/55 focus-visible:ring-offset-2 focus-visible:ring-offset-background sm:p-8"
          >
            <div
              class="pointer-events-none absolute inset-0 rounded-[inherit] bg-gradient-to-br from-brand/[0.1] via-amber-500/[0.07] to-amber-500/[0.11] dark:from-brand/[0.1] dark:via-amber-500/[0.055] dark:to-amber-500/[0.09]"
              aria-hidden="true"
            />
            <div
              class="pointer-events-none absolute inset-0 rounded-[inherit] bg-[radial-gradient(65%_55%_at_100%_0%,color-mix(in_oklch,var(--color-brand)_14%,transparent),transparent_72%),radial-gradient(55%_50%_at_0%_100%,color-mix(in_oklch,var(--color-amber-500)_12%,transparent),transparent_70%)] dark:bg-[radial-gradient(65%_55%_at_100%_0%,color-mix(in_oklch,var(--color-brand)_14%,transparent),transparent_72%),radial-gradient(55%_50%_at_0%_100%,color-mix(in_oklch,var(--color-amber-500)_11%,transparent),transparent_70%)]"
              aria-hidden="true"
            />
            <div
              class="pointer-events-none absolute -right-16 -top-24 size-56 rounded-full bg-brand/[0.08] blur-3xl dark:bg-brand/10"
              aria-hidden="true"
            />
            <div
              class="pointer-events-none absolute -bottom-20 -left-10 size-48 rounded-full bg-amber-500/[0.08] blur-3xl dark:bg-amber-500/10"
              aria-hidden="true"
            />
            <div
              class="relative z-[1] flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between lg:gap-10"
            >
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-brand/30 bg-brand/15 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-brand">
                    <Sparkles className="size-3" aria-hidden="true" />
                    Em destaque
                  </span>
                  <span
                    class="inline-flex items-center rounded-full border border-amber-500/30 bg-amber-500/10 px-2 py-0.5 text-[10px] font-medium text-amber-900 dark:text-amber-300"
                  >
                    Refração
                  </span>
                  <span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-2 py-0.5 text-[10px] font-medium text-muted-foreground">
                    {presbiopiaSpotlight.data.readingTime}
                  </span>
                </div>
                <div class="mt-4 flex items-start gap-3">
                  <span
                    class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-xl border border-brand/25 bg-brand/10 text-brand"
                    aria-hidden="true"
                  >
                    <Eye className="size-5" />
                  </span>
                  <div class="min-w-0">
                    <h3 class="text-xl font-bold leading-tight tracking-tight text-foreground sm:text-2xl">
                      Vista cansada após os 40? Entenda a presbiopia
                    </h3>
                    <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
                      Dificuldade para ler e para focar no celular de perto, com sensação de braço curto?
                      Entenda o que muda no olho e quais opções existem, de óculos a cirurgia, com
                      orientação clínica clara.
                    </p>
                  </div>
                </div>
              </div>
              <div class="flex shrink-0 flex-col items-stretch gap-2 sm:flex-row sm:items-center lg:flex-col xl:flex-row">
                <span
                  class="inline-flex items-center justify-center gap-2 rounded-xl border border-brand/40 bg-brand px-5 py-3 text-sm font-semibold text-brand-foreground shadow-sm transition-colors group-hover:bg-brand/90"
                >
                  Abrir guia completo
                  <ArrowRight
                    className="size-4 transition-transform group-hover:translate-x-0.5"
                    aria-hidden="true"
                  />
                </span>
              </div>
            </div>
          </a>
        </div>
      )
    }

    <div
      class:list={[
        "scroll-3d-stage grid gap-5 sm:grid-cols-2 lg:grid-cols-3",
        presbiopiaSpotlight ? "mt-10" : "mt-14",
      ]}
    >
      {
        items.map((article) => {
          const cat = categoryStyles[article.data.hubCategory];
          return (
            <article
              class={`surface-lift scroll-card-depth scroll-card-motion h-full rounded-2xl border border-border/50 bg-card transition-colors hover:border-border hover:shadow-sm ${cat.ring}`}
            >
              <a
                href={`/conteudos/${article.id}`}
                id={`gtm-home-conteudo-${article.id}`}
                class="group flex h-full flex-col rounded-2xl p-6 outline-none transition-colors focus-visible:ring-2 focus-visible:ring-brand/55 focus-visible:ring-offset-2 focus-visible:ring-offset-background"
              >
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class={`inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium ${cat.badge}`}
                  >
                    {cat.label}
                  </span>
                  <span class="inline-flex items-center rounded-full border border-brand/20 bg-brand/10 px-2 py-0.5 text-[10px] font-medium text-brand">
                    {article.data.readingTime}
                  </span>
                </div>
                <h3 class="mt-3 text-lg font-semibold leading-snug tracking-tight text-foreground transition-colors group-hover:text-brand sm:text-xl">
                  {article.data.condition}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground line-clamp-3">
                  {article.data.description}
                </p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-brand">
                  Ler guia completo
                  <Sparkles className="size-3.5 opacity-90" aria-hidden="true" />
                </span>
              </a>
            </article>
          );
        })
      }
    </div>

    <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/conteudos"
        id="gtm-home-conteudos-hub"
        class={`${buttonVariants({ size: "lg" })} px-8 text-base`}
      >
        Ver todos os conteúdos
      </a>
      <a
        href="/agendamento-online"
        id="gtm-home-conteudos-agendar"
        class={`${buttonVariants({ variant: "outline", size: "lg" })} px-8 text-base`}
      >
        Agendar consulta
      </a>
    </div>

    <p class="mx-auto mt-6 max-w-2xl text-center text-xs leading-relaxed text-muted-foreground">
      Os guias são de autoria de {siteConfig.name}, oftalmologista com ênfase em retina e catarata,
      em linguagem direta para apoiar escolhas conscientes no cuidado com a visão — inclusive em{" "}
      {cityName} e nas demais cidades onde há atendimento.
    </p>
  </div>
</section>
