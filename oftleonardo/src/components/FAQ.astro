---
import AnimatedSection from "./AnimatedSection";
import FAQAccordion from "./FAQAccordion";
---

<section id="faq" class="py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <AnimatedSection client:visible>
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Perguntas Frequentes
        </h2>
        <p class="mt-4 text-muted-foreground">
          Respostas claras sobre especialidades, procedimentos e como agendar sua consulta.
        </p>
      </div>
    </AnimatedSection>

    <AnimatedSection client:visible delay={0.15}>
      <div class="mt-12">
        <FAQAccordion client:visible />
      </div>
    </AnimatedSection>
  </div>
</section>
