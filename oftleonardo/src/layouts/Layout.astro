---
import "../styles/global.css";
import { siteConfig } from "@/config/site";
import JsonLd from "@/components/JsonLd.astro";
import TrackingAndConsent from "@/components/TrackingAndConsent.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogType?: string;
  includeFAQSchema?: boolean;
}

const {
  title = siteConfig.meta.title,
  description = siteConfig.meta.description,
  keywords = siteConfig.meta.keywords,
  ogType = "website",
  includeFAQSchema = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteConfig.canonical);
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="oftleonardo" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content={siteConfig.meta.themeColor} />
    <meta name="msapplication-TileColor" content={siteConfig.meta.themeColor} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content={siteConfig.name} />
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(siteConfig.meta.ogImage, siteConfig.canonical).href} />
    <meta property="og:image:width" content={String(siteConfig.meta.ogImageWidth)} />
    <meta property="og:image:height" content={String(siteConfig.meta.ogImageHeight)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`${siteConfig.name} · ${siteConfig.title}`} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content={`${siteConfig.name} · ${siteConfig.title}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(siteConfig.meta.ogImage, siteConfig.canonical).href} />
    <meta name="twitter:image:alt" content={`${siteConfig.name} · ${siteConfig.title}`} />

    <!-- Geo / Medical -->
    <meta name="geo.region" content="BR-CE" />
    <meta name="geo.placename" content="Fortaleza" />

    <JsonLd includeFAQ={includeFAQSchema} />
    <TrackingAndConsent />
    <slot name="head" />
    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "dark" || (!t && matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <a href="#conteudo-principal" class="skip-link">Pular para o conteúdo principal</a>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
