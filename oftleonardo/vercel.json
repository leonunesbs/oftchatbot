{
  "redirects": [
    {
      "source": "/calculadora-osdi",
      "destination": "/calculadora-olho-seco",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
