# Copie para `.env` e ajuste. Valores vazios são opcionais.

# -----------------------------------------------------------------------------
# Site em manutenção (middleware). "true" exibe página estática de construção.
# Nome legado alinhado ao oftagenda; funciona em build/deploy (ex.: Vercel).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_UNDER_CONSTRUCTION=false

# -----------------------------------------------------------------------------
# Google Tag Manager — mesmo container que o oftagenda, se aplicável.
# Só tem efeito em produção (PROD).
# -----------------------------------------------------------------------------
PUBLIC_GTM_ID=GTM-5TT2VLT6

# -----------------------------------------------------------------------------
# Origens extras permitidas para Origin/Referer nas rotas de API (CORS implícito).
# Lista separada por vírgula: URLs completas (https://...) ou apenas hostname.
# Sempre inclui o próprio host da requisição.
# -----------------------------------------------------------------------------
ALLOWED_API_ORIGINS=https://oftleonardo.com.br,agenda.oftleonardo.com.br

# -----------------------------------------------------------------------------
# Porta local do `pnpm dev` (padrão 4331 no package.json se omitido).
# -----------------------------------------------------------------------------
PORT=4331
